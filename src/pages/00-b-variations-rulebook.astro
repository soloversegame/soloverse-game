---
// src/pages/variations.astro
// Premium, native web text Soloverse Variations Rulebook configuration
---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <!-- Permanent Cache-Busting Network Headers -->
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate" />
    <meta http-equiv="Pragma" content="no-cache" />
    <meta http-equiv="Expires" content="0" />

    <title>Soloverse Variations Rulebook</title>
    <style>
        :root {
            --bg-main: #0f1015;
            --bg-card: #171922;
            --bg-main-box: #1c1e27;
            --text-primary: #ffffff;
            --text-secondary: #f3f4f6;
            --text-muted: #9ca3af;
            --text-divider: #2d313f;
            --color-accent: #3b82f6;
        }

        :root[data-theme="light"] {
            --bg-main: #f4f5f7;
            --bg-card: #ffffff;
            --bg-main-box: #f9fafb;
            --text-primary: #111216;
            --text-secondary: #1f2937;
            --text-muted: #4b5563;
            --text-divider: #d1d5db;
            --color-accent: #1d4ed8;
        }

        body {
            font-family: system-ui, -apple-system, sans-serif;
            background: var(--bg-main);
            color: var(--text-secondary);
            max-width: 750px;
            margin: 40px auto;
            padding: 20px;
            line-height: 1.7;
            transition: background 0.3s, color 0.3s;
        }
        .back-link {
            display: inline-block;
            color: var(--color-accent);
            text-decoration: none;
            font-weight: 700;
            margin-bottom: 25px;
            transition: color 0.15s;
        }
        .back-link:hover { color: var(--text-primary); }
        h1 { font-size: 2.3rem; color: var(--text-primary); margin-bottom: 5px; font-weight: 800; letter-spacing: -0.03em; }
        .meta-tag { color: var(--text-muted); font-size: 0.95rem; margin-bottom: 40px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; }
        
        /* Index Jump Matrix */
        .toc-box { 
            background: var(--bg-card); 
            border: 1px solid var(--text-divider); 
            padding: 24px; 
            border-radius: 12px; 
            margin: 30px 0; 
        }
        .toc-title { margin: 0 0 15px 0; color: var(--text-primary); font-size: 1.1rem; font-weight: 700; }
        .toc-list { list-style: none; padding: 0; margin: 0; display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 10px; }
        .toc-link { color: var(--text-muted); text-decoration: none; font-weight: 600; transition: color 0.15s; }
        .toc-link:hover { color: var(--color-accent); }

        h2 { font-size: 1.5rem; color: var(--text-primary); margin-top: 50px; border-bottom: 1px solid var(--text-divider); padding-bottom: 8px; font-weight: 700; }
        p { color: var(--text-secondary); margin: 16px 0; }
        ul { margin: 0 0 16px 0; padding-left: 20px; color: var(--text-secondary); }
        li { margin-bottom: 8px; }

        .variation-box {
            background: var(--bg-card);
            border: 1px solid var(--text-divider);
            padding: 24px;
            border-radius: 12px;
            margin: 20px 0;
            display: flex;
            flex-direction: column;
            gap: 15px;
        }
        .example-box {
            font-size: 0.92rem;
            background: var(--bg-main-box);
            padding: 12px;
            border-radius: 8px;
            border-left: 3px solid var(--color-accent);
            color: var(--text-secondary);
        }
        .note-box {
            font-size: 0.92rem;
            background: rgba(255, 242, 0, 0.03);
            padding: 12px;
            border-radius: 8px;
            border-left: 3px solid #fff200;
            color: var(--text-secondary);
        }
    </style>
</head>
<body id="top">

    <a href="/" class="back-link">📂 Return to Shelf Deck</a>

    <h1>[00-B] SOLOVERSE [VARIATIONS RULEBOOK]</h1>
    <div class="meta-tag">⚙️ Universal Deck Modification Suite • v2.0.0</div>

    <!-- USAGE NOTES SECTION -->
    <div style="background: var(--bg-card); border: 1px solid var(--text-divider); padding: 20px; border-radius: 12px; border-left: 4px solid var(--color-accent); margin-bottom: 30px;">
        <strong style="color: var(--text-primary); display: block; font-size: 1.05rem; margin-bottom: 8px; text-transform: uppercase; letter-spacing: 0.03em;">USAGE NOTES:</strong>
        <ul style="margin: 0; padding-left: 20px; font-size: 0.95rem; color: var(--text-secondary); display: flex; flex-direction: column; gap: 6px; list-style-type: disc;">
            <li>These Variation Rules are also represented in the Field Deck Expansion [e.g.: Field of Replication &amp; Field of Normalisation].</li>
            <li>Either Choose one Variation Rule here compatible with Your Game Mode or use the Field Deck and it’s Trap Class Chaos Cards to Dynamically change the Variation Rules during the Game.</li>
            <li>Follow the Compatible Games listed in each Rule Variation while using the Field Deck Expansion.</li>
        </ul>
    </div>

    <!-- INDEX JUMP MATRIX -->
    <div class="toc-box">
        <div class="toc-title">📋 Index Jump Matrix</div>
        <ul class="toc-list">
            <li><a href="#v01" class="toc-link">[01: ADDITION]</a></li>
            <li><a href="#v02" class="toc-link">[02: SUBTRACTION]</a></li>
            <li><a href="#v03" class="toc-link">[03: ESCALATION]</a></li>
            <li><a href="#v04" class="toc-link">[04: REDUCTION]</a></li>
            <li><a href="#v05" class="toc-link">[05: SUCCESSION]</a></li>
            <li><a href="#v06" class="toc-link">[06: REPLICATION]</a></li>
            <li><a href="#v07" class="toc-link">[07: DECEPTION]</a></li>
            <li><a href="#v08" class="toc-link">[08: NORMALISATION]</a></li>
        </ul>
    </div>

    <!-- [01: ADDITION] -->
    <h2 id="v01">[01: ADDITION]</h2>
    <div class="variation-box">
        <p style="margin: 0; font-weight: 600;">1. Compatible with Soloverse [Crazy 8’s], [Crazy 8’s Utter Chaos], [Karma] &amp; [Cheat].</p>
        <p style="margin: 0; font-weight: 600; color: var(--text-primary);">2. The Main Changes are as Follows:</p>
        <ul style="margin: 0; padding-left: 20px; list-style-type: lower-alpha;">
            <li>Every Number Card Played MUST be Higher than the Previous one Played.</li>
            <li>Any Action or Chaos Card Played are resolved as normal [e.g.: Choose a Colour to Continue after Resolving a Chaos Card], however it also Resets the Number Played, allowing any to be Played.</li>
        </ul>
    </div>
    <div style="text-align: right; margin-top: 10px;">
        <a href="#top" style="color: var(--color-accent); text-decoration: none; font-size: 0.88rem; font-weight: 700;">🔝 Return to Index Matrix</a>
    </div>

    <!-- [02: SUBTRACTION] -->
    <h2 id="v02">[02: SUBTRACTION]</h2>
    <div class="variation-box">
        <p style="margin: 0; font-weight: 600;">1. Compatible with Soloverse [Crazy 8’s], [Crazy 8’s Utter Chaos], [Karma] &amp; [Cheat].</p>
        <p style="margin: 0; font-weight: 600; color: var(--text-primary);">2. The Main Changes are as Follows:</p>
        <ul style="margin: 0; padding-left: 20px; list-style-type: lower-alpha;">
            <li>Every Number Card Played MUST be Lower than the Previous one Played.</li>
            <li>Any Action or Chaos Card Played are resolved as normal [e.g.: Choose a Colour to Continue after Resolving a Chaos Card], however it also Resets the Number Played, allowing any to be Played.</li>
        </ul>
    </div>
    <div style="text-align: right; margin-top: 10px;">
        <a href="#top" style="color: var(--color-accent); text-decoration: none; font-size: 0.88rem; font-weight: 700;">🔝 Return to Index Matrix</a>
    </div>

    <!-- [03: ESCALATION] -->
    <h2 id="v03">[03: ESCALATION]</h2>
    <div class="variation-box">
        <p style="margin: 0; font-weight: 600;">1. Compatible with Soloverse [Crazy 8’s], [Crazy 8’s Utter Chaos], [Karma] &amp; [Cheat].</p>
        <p style="margin: 0; font-weight: 600; color: var(--text-primary);">2. The Main Changes are as Follows:</p>
        <ul style="margin: 0 0 5px 0; padding-left: 20px; list-style-type: lower-alpha;">
            <li>Every Number Card Played MUST be Sequentially Higher than the Previous one Played.</li>
        </ul>
        <div class="example-box">
            <strong>EXAMPLE:</strong> 0, 1, 2, 3, 4…
        </div>
        <ul style="margin: 0; padding-left: 20px; list-style-type: lower-alpha; start: 2;">
            <li style="list-style-type: none; margin-left: -20px;">b. Any Action or Chaos Card Played are resolved as normal [e.g.: Choose a Colour to Continue after Resolving a Chaos Card], however it also Resets the Number Played, allowing any to be Played.</li>
        </ul>
    </div>
    <div style="text-align: right; margin-top: 10px;">
        <a href="#top" style="color: var(--color-accent); text-decoration: none; font-size: 0.88rem; font-weight: 700;">🔝 Return to Index Matrix</a>
    </div>

    <!-- [04: REDUCTION] -->
    <h2 id="v04">[04: REDUCTION]</h2>
    <div class="variation-box">
        <p style="margin: 0; font-weight: 600;">1. Compatible with Soloverse [Crazy 8’s], [Crazy 8’s Utter Chaos], [Karma] &amp; [Cheat].</p>
        <p style="margin: 0; font-weight: 600; color: var(--text-primary);">2. The Main Changes are as Follows:</p>
        <ul style="margin: 0 0 5px 0; padding-left: 20px; list-style-type: lower-alpha;">
            <li>Every Number Card Played MUST be Sequentially Lower than the Previous one Played.</li>
        </ul>
        <div class="example-box">
            <strong>EXAMPLE:</strong> 9, 8, 7, 6…
        </div>
        <ul style="margin: 5px 0 0 0; padding-left: 20px; list-style-type: none;">
            <li style="margin-left: -20px;">b. Any Action or Chaos Card Played are resolved as normal [e.g.: Choose a Colour to Continue after Resolving a Chaos Card], however it also Resets the Number Played, allowing any to be Played.</li>
        </ul>
    </div>
    <div style="text-align: right; margin-top: 10px; margin-bottom: 30px;">
        <a href="#top" style="color: var(--color-accent); text-decoration: none; font-size: 0.88rem; font-weight: 700;">🔝 Return to Index Matrix</a>
    </div>

    <!-- [05: SUCCESSION] -->
    <h2 id="v05">[05: SUCCESSION]</h2>
    <div class="variation-box">
        <p style="margin: 0; font-weight: 600;">1. Compatible with Soloverse [Crazy 8’s], [Crazy 8’s Utter Chaos], [Karma] &amp; [Cheat].</p>
        <p style="margin: 0; font-weight: 600; color: var(--text-primary);">2. The Main Changes are as Follows:</p>
        <ul style="margin: 0 0 5px 0; padding-left: 20px; list-style-type: lower-alpha;">
            <li>Every Number Card Played MUST be Sequentially Higher or Lower than the Previous one Played.</li>
        </ul>
        <div class="example-box">
            <strong>EXAMPLE:</strong> 5, 4, 5, 6, 7, 6…
        </div>
        <ul style="margin: 5px 0 0 0; padding-left: 20px; list-style-type: none;">
            <li style="margin-left: -20px;">b. Any Action or Chaos Card Played are resolved as normal [e.g.: Choose a Colour to Continue after Resolving a Chaos Card], however it also Resets the Number Played, allowing any to be Played.</li>
        </ul>
    </div>
    <div style="text-align: right; margin-top: 10px; margin-bottom: 30px;">
        <a href="#top" style="color: var(--color-accent); text-decoration: none; font-size: 0.88rem; font-weight: 700;">🔝 Return to Index Matrix</a>
    </div>

    <!-- [06: REPLICATION] -->
    <h2 id="v06">[06: REPLICATION]</h2>
    <div class="variation-box">
        <p style="margin: 0; font-weight: 600;">1. Compatible with Soloverse [Crazy 8’s] &amp; [Crazy 8’s Utter Chaos].</p>
        <p style="margin: 0; font-weight: 600; color: var(--text-primary);">2. The Main Changes are as Follows:</p>
        <ul style="margin: 0; padding-left: 20px; list-style-type: lower-alpha;">
            <li>Multiple Copies of Number Cards can be Played if they are of Equal Value.</li>
            <li>Any Action or Chaos Card Played are resolved as normal [e.g.: Choose a Colour to Continue after Resolving a Chaos Card], however it also Resets the Number Played, allowing any to be Played.</li>
        </ul>
    </div>
    <div style="text-align: right; margin-top: 10px; margin-bottom: 30px;">
        <a href="#top" style="color: var(--color-accent); text-decoration: none; font-size: 0.88rem; font-weight: 700;">🔝 Return to Index Matrix</a>
    </div>

    <!-- [07: DECEPTION] -->
    <h2 id="v07">[07: DECEPTION]</h2>
    <div class="variation-box">
        <p style="margin: 0; font-weight: 600;">1. Compatible with Soloverse [Crazy 8’s], [Crazy 8’s Utter Chaos] &amp; [Karma].</p>
        <p style="margin: 0; font-weight: 600; color: var(--text-primary);">2. The Main Changes are as follows:</p>
        <ul style="margin: 0 0 10px 0; padding-left: 20px; list-style-type: lower-alpha;">
            <li>On your turn, you place Your Cards Face-Down instead, calling out what Cards you placed and how many there were, mimicking Soloverse [Cheat]’s Rules.</li>
        </ul>
        <div class="note-box" style="margin-top: -5px; margin-bottom: 15px;">
            <strong>NOTE:</strong> You do not have to tell the truth about the number of cards or their value.
        </div>
        <ul style="margin: 0; padding-left: 20px; list-style-type: none;">
            <li style="margin-left: -20px; margin-bottom: 8px;">b. Cheating is allowed. But you will be penalised for getting caught.</li>
            <li style="margin-left: -20px; margin-bottom: 8px;">c. Play continues likewise, with the next Player doing the same.</li>
        </ul>
        <div class="note-box" style="margin-top: 5px; margin-bottom: 15px;">
            <strong>NOTE:</strong> At any point, any other Player can call “Cheat!” At which point the last Player who put down MUST reveal their cards.
        </div>
        <ul style="margin: 0; padding-left: 40px; list-style-type: lower-roman;">
            <li style="margin-bottom: 6px;">If the Player was in fact cheating, They MUST now pick up the entire Discards.</li>
            <li>If the Player was indeed telling the truth, the Challenging Player MUST pick up the entire Discards instead!</li>
        </ul>
    </div>
    <div style="text-align: right; margin-top: 10px; margin-bottom: 30px;">
        <a href="#top" style="color: var(--color-accent); text-decoration: none; font-size: 0.88rem; font-weight: 700;">🔝 Return to Index Matrix</a>
    </div>

    <!-- [08: NORMALISATION] -->
    <h2 id="v08">[08: NORMALISATION]</h2>
    <div class="variation-box">
        <p style="margin: 0; font-weight: 600;">1. Follow all Rules for the Soloverse Rulebook being Played.</p>
        <p style="margin: 0; font-weight: 600; color: var(--text-primary);">2. There are no Changes.</p>
    </div>
    
    <div style="text-align: right; margin-top: 15px; margin-bottom: 40px;">
        <a href="#top" style="color: var(--color-accent); text-decoration: none; font-size: 0.88rem; font-weight: 700;">🔝 Return to Index Matrix</a>
    </div>

    <!-- Soloverse Rulebook Page Engine: Auto-Theme Detection & Update Sync -->
    <script is:inline>
        (function() {
            // 1. SERVICE WORKER REVALIDATION
            if ('serviceWorker' in navigator) {
                navigator.serviceWorker.getRegistrations().then(function(registrations) {
                    for (let registration of registrations) {
                        registration.update(); 
                    }
                });
            }

            // 2. AUTOMATED THEME EVALUATION (User Override vs System Preference)
            const savedTheme = localStorage.getItem('soloverse-theme');
            const devicePrefersDarkMode = window.matchMedia('(prefers-color-scheme: dark)').matches;
            
            let activeTheme = 'dark'; // Base anchor default fallback

            if (savedTheme) {
                // Priority 1: Respect explicit button clicks from the main bookshelf hub
                activeTheme = savedTheme;
            } else {
                // Priority 2: Auto-adopt the tablet/device's native operating system mode
                activeTheme = devicePrefersDarkMode ? 'dark' : 'light';
            }

            // Mount theme instantly to root document element
            document.documentElement.setAttribute('data-theme', activeTheme);
        })();
    </script>
</body>
</html>