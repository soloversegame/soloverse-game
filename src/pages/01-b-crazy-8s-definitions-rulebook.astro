---
// src/pages/core-action-class.astro
// Premium, native web text core-action-class game rulebook
---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Core Game: Action Class Cards</title>
    <style>
        :root {
            --bg-main: #0f1015;
            --bg-card: #171922;
            --bg-main-box: #1c1e27;
            --text-primary: #ffffff;
            --text-secondary: #f3f4f6;
            --text-muted: #9ca3af;
            --text-divider: #2d313f;
            --color-accent: #0000ff;
            --color-link: #3b82f6;
        }
        :root[data-theme="light"] {
            --bg-main: #f4f5f7;
            --bg-card: #ffffff;
            --bg-main-box: #f9fafb;
            --text-primary: #111216;
            --text-secondary: #1f2937;
            --text-muted: #4b5563;
            --text-divider: #d1d5db;
            --color-link: #1d4ed8;
        }

        body {
            background-color: var(--bg-main);
            color: var(--text-primary);
            font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            margin: 0;
            padding: 20px;
            line-height: 1.6;
        }

        .rules-box {
            background: var(--bg-card);
            border: 1px solid var(--text-divider);
            padding: 24px;
            border-radius: 12px;
            margin: 20px 0;
            display: flex;
            flex-direction: column;
            gap: 15px;
        }
        .note-box {
            font-size: 0.92rem;
            background: rgba(255, 242, 0, 0.03);
            padding: 12px;
            border-radius: 8px;
            border-left: 3px solid #fff200;
            color: var(--text-secondary);
        }
        .return-link-wrapper {
            text-align: right;
            margin-top: -10px;
            margin-bottom: 30px;
        }
        .return-link {
            color: var(--color-link);
            text-decoration: none;
            font-size: 0.9rem;
            font-weight: 500;
        }
        .return-link:hover {
            text-decoration: underline;
        }

        .image-container {
            margin: 20px auto;
            padding: 12px;
            background: var(--bg-main-box);
            border: 1px solid var(--text-divider);
            border-radius: 8px;
            text-align: center;
            max-width: 100%;
        }
        .image-container img {
            max-width: 100%;
            max-height: 450px;
            width: auto;
            height: auto;
            object-fit: contain;
            border-radius: 6px;
            display: block;
            margin: 0 auto;
            border: 1px solid var(--text-divider);
        }
        .image-caption {
            font-size: 0.85rem;
            color: var(--text-muted);
            margin-top: 10px;
            font-weight: 500;
            line-height: 1.4;
        }

        /* Flexbox row layout for side-by-side preview images */
        .image-row-container {
            display: flex;
            flex-wrap: wrap;
            gap: 15px;
            justify-content: center;
            margin: 20px 0;
            width: 100%;
        }
        /* Overrides standard margins when images sit inside a row grid */
        .image-row-container .image-container {
            flex: 1 1 calc(33.333% - 15px); /* Displays 3 per row on desktop */
            min-width: 220px; /* Forces stack drop on smaller screens */
            margin: 0; 
        }

        /* Core Game Custom Border Skins */
        .image-container.border-steel { border: 3px solid #1d4ed8; box-shadow: 0 0 12px rgba(29, 78, 216, 0.2); }
        .image-container.border-poison-core { border: 3px solid #6b21a8; box-shadow: 0 0 12px rgba(107, 33, 168, 0.2); }
        .image-container.border-venom-core { border: 3px solid #dc2626; box-shadow: 0 0 12px rgba(220, 38, 38, 0.2); }
        .image-container.border-carbon { border: 3px solid #ea580c; box-shadow: 0 0 12px rgba(234, 88, 12, 0.2); }
        .image-container.border-stinger-core { border: 3px solid #eab308; box-shadow: 0 0 12px rgba(234, 179, 8, 0.2); }
        .image-container.border-toxin-core { border: 3px solid #16a34a; box-shadow: 0 0 12px rgba(22, 163, 74, 0.2); }

        /* Coloured Extensions Custom Border Skins */
        .image-container.border-diamond { border: 3px solid #3b82f6; box-shadow: 0 0 12px rgba(59, 130, 246, 0.2); }
        .image-container.border-emerald { border: 3px solid #10b981; box-shadow: 0 0 12px rgba(16, 185, 129, 0.2); }
        .image-container.border-redwood { border: 3px solid #5c4033; box-shadow: 0 0 12px rgba(92, 64, 51, 0.2); }
        .image-container.border-oak { border: 3px solid #b58900; box-shadow: 0 0 12px rgba(181, 137, 0, 0.2); }
        .image-container.border-rose { border: 3px solid #ec4899; box-shadow: 0 0 12px rgba(236, 72, 153, 0.2); }
        .image-container.border-amethyst { border: 3px solid #8b5cf6; box-shadow: 0 0 12px rgba(139, 92, 246, 0.2); }
        .image-container.border-stone { border: 3px solid #6b7280; box-shadow: 0 0 12px rgba(107, 114, 128, 0.2); }

        h2 { margin: 0; color: var(--text-primary); }
        ul { margin: 0; padding-left: 20px; }
        li { margin-bottom: 8px; }

        @media screen and (min-width: 768px) and (orientation: landscape) {
            body {
                max-width: 960px;
                margin: 40px auto;
                padding: 0 30px;
            }
            .rules-box { padding: 32px; margin: 24px 0; }
        }
        @media screen and (min-width: 1024px) {
            body { max-width: 1050px; }
        }
    </style>
</head>
<body>

    <div id="top"></div>

    <h1>[01-A] SOLOVERSE - CRAZY 8’s</h1>
    <div class="meta-tag">[DEFINITIONS RULEBOOK] • 👥 Ages 7+, 3-10 Players • v14.0.0</div>

    <!-- CORE COLOURED SETS ENGINE INDICATORS -->
    <div id="core-colours-framework">
        <div class="rules-box">
            <h2>CORE GAME COLOURED SETS</h2>
            <p>For architectural continuity across the card vault platform, these are the visual engine indicators for the 6 core deck colours referenced throughout this rulebook [01.1, 01.2]:</p>
            
            <div class="image-container border-steel">
                <img src="/assets/images/cards/000-1-steel-0.png" alt="Steel Core Set Game Preview" />
                <div class="image-caption">Steel (Dark Blue Base Set Frame Layout) [01.1, 01.2]</div>
            </div>
            
            <div class="image-container border-stinger-core">
                <img src="/assets/images/cards/000-5-stinger-5.png" alt="Stinger Core Game Set Preview" />
                <div class="image-caption">Stinger (Yellow Base Set Frame Layout) [01.1, 01.2]</div>
            </div>
            
            <div class="image-container border-toxin-core">
                <img src="/assets/images/cards/000-4-toxin-4.png" alt="Toxin Core Game Set Preview" />
                <div class="image-caption">Toxin (Dark Green Base Set Frame Layout) [01.1, 01.2]</div>
            </div>

            <div class="image-container border-poison-core">
                <img src="/assets/images/cards/000-12-poison-reverse.png" alt="Poison Core Game Set Preview" />
                <div class="image-caption">Poison (Dark Purple Base Set Frame Layout) [01.1, 01.2]</div>
            </div>
            
            <div class="image-container border-venom-core">
                <img src="/assets/images/cards/000-9-venom-9.png" alt="Venom Core Game Set Preview" />
                <div class="image-caption">Venom (Red Base Set Frame Layout) [01.1, 01.2]</div>
            </div>
            
            <div class="image-container border-carbon">
                <img src="/assets/images/cards/000-6-carbon-6.png" alt="Carbon Core Extension Set Preview" />
                <div class="image-caption">Carbon (Orange Base Set Frame Layout) [01.1, 01.2]</div>
            </div>
		</div>

        <div class="return-link-wrapper">
            <a href="#top" class="return-link">🔝 Return to Index Matrix</a>
        </div>
    </div>

</head>
<body>

    <div id="top"></div>

    <!-- FUNCTIONS OF THE CORE GAME’S ACTION CLASS CARDS -->
    <div id="action-class-framework">
        <div class="rules-box">
            <h2>FUNCTIONS OF THE CORE GAME’S ACTION CLASS CARDS:</h2>
        </div>
    </div>

    <!-- DRAW +2 -->
    <div id="draw-two">
        <div class="rules-box">
            <h2>DRAW +2 [x 12]:</h2>
            <div>Action Class | Single Targeting | Stackable | 2 x each: Steel, Poison, Venom, Carbon, Stinger &amp; Toxin [01.1]</div>
            
            <div class="image-container">
                <img src="/assets/images/cards/000-1-steel-draw-2.png" alt="Draw +2" />
                <div class="image-caption">Draw +2 Card Blueprint Component</div>
            </div>

            <ul>
                <li>• When played, the next Player MUST Draw 2 Cards and Skip Their Turn OR Respond in Kind [passing Stacked Effects onto the next Player] [01.1].</li>
            </ul>

            <div class="note-box">
                <strong>COMPATIBILITY NOTE:</strong> CANNOT Stack with the Chaos Draw +4 Chaos Card [see: Apocalypse Expansion for options here] [01.1].
            </div>
        </div>
        <div class="return-link-wrapper">
            <a href="#top" class="return-link">🔝 Return to Index Matrix</a>
        </div>
    </div>

    <!-- REVERSE -->
    <div id="reverse">
        <div class="rules-box">
            <h2>REVERSE [x 12]:</h2>
            <div>Action Class | Group Targeting | 2 x each: Steel, Poison, Venom, Carbon, Stinger &amp; Toxin [01.2]</div>

            <div class="image-container">
                <img src="/assets/images/cards/000-4-toxin-reverse.png" alt="Reverse" />
                <div class="image-caption">Reverse Card Blueprint Component</div>
            </div>

            <ul>
                <li>• When played, the Direction of Play Reverses [01.2].</li>
            </ul>

            <div class="note-box">
                <strong>COMPATIBILITY NOTE:</strong> Compatible with all Reverse Symbol Cards [e.g.: the Pure Chaos Reverse or Chaos Draw +4 Reverse] [01.2].
            </div>

            <div class="note-box">
                <strong>2 PLAYER GAME NOTE:</strong> Reverse’s Effect no longer works; however, You CAN still match its Symbol [01.2].
            </div>
        </div>
        <div class="return-link-wrapper">
            <a href="#top" class="return-link">🔝 Return to Index Matrix</a>
        </div>
    </div>

    <!-- SKIP -->
    <div id="skip">
        <div class="rules-box">
            <h2>SKIP [x 12]:</h2>
            <div>Action Class | Single Targeting | 2 x each: Steel, Poison, Venom, Carbon, Stinger &amp; Toxin [01.2]</div>

            <div class="image-container">
                <img src="/assets/images/cards/000-9-venom-skip.png" alt="Skip" />
                <div class="image-caption">Skip Card Blueprint Component</div>
            </div>

            <ul>
                <li>• When played, the next Player Skips Their Turn [01.2].</li>
            </ul>

            <div class="note-box">
                <strong>COMPATIBILITY NOTE:</strong> Compatible with all Skip Symbol Cards [e.g.: the Pure Chaos Skip or Chaos Draw +4 Skip Chaos Cards] [01.2].
            </div>

            <div class="note-box">
                <strong>NOTE:</strong> Just because I got creative with the Colour Names, doesn’t mean You have to use them... Dark Blue, Dark Purple, Red, Orange, Yellow &amp; Dark Green are fine... [compare: Coloured Extensions] [01.2].
            </div>
        </div>
        <div class="return-link-wrapper">
            <a href="#top" class="return-link">🔝 Return to Index Matrix</a>
        </div>
    </div>

    <!-- FUNCTIONS OF THE CORE GAME, CORE EXTENSION & CORE BOOSTER PACK’S NORMAL CLASS CHAOS CARDS -->
    <div id="normal-class-rules-framework">
        <div class="rules-box">
            <h2>FUNCTIONS OF THE CORE GAME, CORE EXTENSION &amp; CORE BOOSTER PACK’S NORMAL CLASS CHAOS CARDS:</h2>
            <ul>
                <li>• 3 PLAYERS REQUIRED FOR MINIMUM USE:</li>
                <li>• 5 PLAYERS RECOMMENDED FOR EFFECTIVE USE.</li>
                <li>RESTRICTION: You CANNOT activate Additional Chaos Cards [i.e.: Counter Class Chaos Cards] in response to Your own Card, on Your own Turn.</li>
                <li>ALTERNATE USE: These Chaos Cards CAN be used as a Pure Chaos Card instead, if chosen – Unless otherwise specified.</li>
                <li>COUNTERING: These Chaos Cards CAN be Countered – Unless otherwise specified. The Trap Class Chaos Cards CANNOT be Countered.</li>
            </ul>
            <div class="note-box">
                NOTE: All Chaos Cards with an Asterisk [*] are from the Core Extension.
            </div>
        </div>
        <div class="return-link-wrapper">
            <a href="#top" class="return-link">🔝 Return to Index Matrix</a>
        </div>
    </div>

    <!-- *BADGE COLLECTOR [x 3] -->
    <div id="badge-collector">
        <div class="rules-box">
            <h2>*BADGE COLLECTOR [x 3]:</h2>
            <div>Normal Class | Self Targeting</div>
            
            <div class="image-container">
                <img src="/assets/images/cards/01-core-extension-badge-collector.png" alt="Badge Collector" />
                <div class="image-caption">Badge Collector Card Template Placeholder</div>
            </div>

            <div>Play to the side of the Discards.</div>
            <ol>
                <li>1. Discard a Minimum of 3 Differently Coloured Cards [one for any of the Coloured Sets]. Then place this Card on top of the Discards.</li>
                <li>2. Choose a Colour to continue.</li>
            </ol>
        </div>
        <div class="return-link-wrapper">
            <a href="#top" class="return-link">🔝 Return to Index Matrix</a>
        </div>
    </div>

    <!-- *BLACK HOLE [x 2] -->
    <div id="black-hole">
        <div class="rules-box">
            <h2>*BLACK HOLE [x 2]:</h2>
            <div>Normal Class | Group Targeting</div>

            <div class="image-container">
                <img src="/assets/images/cards/01-core-extension-black-hole.png" alt="Black Hole" />
                <div class="image-caption">Black Hole Card Template Placeholder</div>
            </div>

            <div>Play to the side of the Discards.</div>
            <ol>
                <li>1. All Players in Play Order Discard all Their Hand Cards.</li>
                <li>
                    COMPATIBILITY NOTE: You CANNOT Discard any SOL/OVE/RSE Cards from the Singularity Expansion.
                </li>
                <li>2. The User now Deals 5 Cards to each Player. Then place this Card on top of the Discards.</li>
                <li>3. Choose a Colour to continue.</li>
            </ol>
            <div>CANNOT be Countered.</div>
        </div>
        <div class="return-link-wrapper">
            <a href="#top" class="return-link">🔝 Return to Index Matrix</a>
        </div>
    </div>

    <!-- CHAOS DRAW +4 [x 3] -->
    <div id="chaos-draw-plus-four">
        <div class="rules-box">
            <h2>CHAOS DRAW +4 [x 3]:</h2>
            <div>Normal Class | Single &amp; Group Targeting | Stackable</div>
            <div>Acts as Draw +4 &amp; Pure Chaos.</div>

            <div class="image-container">
                <img src="/assets/images/cards/00-core-game-chaos-draw-4.png" alt="Chaos Draw +4" />
                <div class="image-caption">Chaos Draw +4 Card Template Placeholder</div>
            </div>

            <ol>
                <li>1. The next Player MUST Draw 4 Cards and Skip Their Turn or Respond in Kind [passing Stacked Effects onto the next Player].</li>
                <li>2. Choose a Colour to continue.</li>
            </ol>
            <div>CANNOT be used as a Pure Chaos Card.</div>
            <div>COMPATIBILITY NOTE: Incompatible with Draw +2 Action Class Cards.</div>
            <div>RESTRICTION: You CAN only play this Card legally if You do NOT have a playable Coloured Card that matches what's in play, or by Responding in Kind.</div>
            <div>EXAMPLE: The Card in Play is a Blue 2. The User CANNOT possess any Blue or any Coloured 2 to legally play a Chaos Draw +4.</div>
            
            <h3>CHALLENGE NOTES:</h3>
            <ol>
                <li>1. You may Challenge a Player when You think they have charged You Draw +4 while having a matching Coloured Card [excluding Responding in Kind].</li>
                <li class="note-box">NOTE: You CAN only Challenge or Respond in Kind… NOT both.</li>
                <li>2. The Challenged Player MUST now show You Their entire Hand privately.</li>
                <li>3. Once a Challenge is issued, the Player in the wrong will be charged an additional 2 Cards on top of the 4 Cards originally needed to be Drawn:
                    <ul>
                        <li>a. If the User was guilty [i.e.: they played it while possessing a matching Coloured Card], they MUST Draw a total of 6 Cards instead of the Challenger.</li>
                        <li>b. If the User was innocent [i.e.: they played it without possessing a matching Coloured Card], the Challenger MUST Draw a total of 6 Cards.</li>
                    </ul>
                </li>
            </ol>
            <div>Challenges CANNOT be Countered.</div>
            <div>TIP: “The additional 2 Card penalty for a failed Challenge is a small price to pay to see what they have up Their sleeve...”</div>
        </div>
        <div class="return-link-wrapper">
            <a href="#top" class="return-link">🔝 Return to Index Matrix</a>
        </div>
    </div>

    <!-- CHAOS DRAW +4 REVERSE [x 3] -->
    <div id="chaos-draw-plus-four-reverse">
        <div class="rules-box">
            <h2>CHAOS DRAW +4 REVERSE [x 3]:</h2>
            <div>Normal Class | Single &amp; Dual Group Targeting | Stackable</div>
            <div>Acts as Draw +4, Reverse &amp; Pure Chaos.</div>

            <div class="image-container">
                <img src="/assets/images/cards/00-core-game-chaos-draw-4-reverse.png" alt="Chaos Draw +4 Reverse" />
                <div class="image-caption">Chaos Draw +4 Reverse Card Template Placeholder</div>
            </div>

            <ol>
                <li>1. The Direction of Play Reverses.</li>
                <li>2. The previous Player MUST Draw 4 Cards and Skip Their Turn or Respond in Kind.</li>
                <li>3. Choose a Colour to continue.</li>
            </ol>
            <div>CANNOT be used as a Pure Chaos Card.</div>
            <div>MUST use Reverse Effect.</div>
            <div class="note-box">2 PLAYER GAME NOTE: The Reverse’s Effect no longer works; however, You CAN still match its Symbol after the Draw Effect has been Resolved.</div>
        </div>
        <div class="return-link-wrapper">
            <a href="#top" class="return-link">🔝 Return to Index Matrix</a>
        </div>
    </div>

    <!-- CHAOS DRAW +4 SKIP [x 3] -->
    <div id="chaos-draw-plus-four-skip">
        <div class="rules-box">
            <h2>CHAOS DRAW +4 SKIP [x 3]:</h2>
            <div>Normal Class | Dual Single &amp; Group Targeting | Stackable</div>
            <div>Acts as Draw +4, Skip &amp; Pure Chaos.</div>

            <div class="image-container">
                <img src="/assets/images/cards/00-core-game-chaos-draw-4-skip.png" alt="Chaos Draw +4 Skip" />
                <div class="image-caption">Chaos Draw +4 Skip Card Template Placeholder</div>
            </div>

            <ol>
                <li>1. The next Player’s Turn is Skipped.</li>
                <li>2. The following Player MUST Draw 4 Cards and Skip Their Turn or Respond in Kind [passing Stacked Effects onto the next Player].</li>
                <li>3. Choose a Colour to continue.</li>
            </ol>
            <div>CANNOT be used as a Pure Chaos Card.</div>
            <div>MUST use Skip Effect.</div>
            <div class="note-box">2 PLAYER GAME NOTE: The Skip’s Effect no longer works; however, You CAN still match its Symbol after the Draw Effect has been Resolved.</div>
        </div>
        <div class="return-link-wrapper">
            <a href="#top" class="return-link">🔝 Return to Index Matrix</a>
        </div>
    </div>

    <!-- CLONE [x 3] -->
    <div id="clone">
        <div class="rules-box">
            <h2>CLONE [x 3]:</h2>
            <div>Normal Class | Unknown Targeting | Stackable</div>

            <div class="image-container">
                <img src="/assets/images/cards/00-core-game-clone.png" alt="Clone" />
                <div class="image-caption">Clone Card Template Placeholder</div>
            </div>

            <ol>
                <li>1. When played, it Copies the Previous Card played [be that a Chaos Draw +4, another Chaos Card or simply a Coloured Number or Action Class Card] as well as any Effects that Card might have [01.4].</li>
                <li>2. Follow the rules for the previous Card [01.4].</li>
            </ol>
            <div>CANNOT be used as a Pure Chaos Card [unless it is Cloned] [01.4].</div>
            <div class="note-box">
                <strong>COMPATIBILITY NOTE:</strong> When copying another Clone Chaos Card, redirect to the first non-Clone Chaos Card on the Discards. CAN even copy the Genetic Manipulation and Steal Turn Chaos Cards [01.4].
            </div>
        </div>
        <div class="return-link-wrapper">
            <a href="#top" class="return-link">🔝 Return to Index Matrix</a>
        </div>
    </div>

    <!-- *CYCLONE [x 2] -->
    <div id="cyclone">
        <div class="rules-box">
            <h2>*CYCLONE [x 2]:</h2>
            <div>Normal Class | Group Targeting | User Goes First</div>

            <div class="image-container">
                <img src="/assets/images/cards/01-core-extension-cyclone.png" alt="Cyclone" />
                <div class="image-caption">Cyclone Card Template Placeholder</div>
            </div>

            <ol>
                <li>1. The User Presents Their Hand Face-Down to the next Player in the current rotation, who Chooses 1 Random Card from it and adds it to Their Hand [01.4].</li>
                <div class="note-box">
                    <strong>TIP:</strong> “Shuffling Your Hand before presenting it Face-Down [without looking at it Yourself] will stop Your Opponents from guessing which Card/s You want to keep.” [01.4]
                </div>
                <li>2. That Player now Presents Their Hand to the next Player, Who Does the Same [01.4].</li>
                <li>3. Continue until the User has Drawn a Card from the previous Player [01.4].</li>
                <li>4. Choose a Colour to continue [01.4].</li>
            </ol>
            <div>CANNOT be Countered [01.4].</div>
            <div>CANNOT be used as a Pure Chaos Card [01.4].</div>
            <div>CANNOT be Your last Card [01.4].</div>
        </div>
        <div class="return-link-wrapper">
            <a href="#top" class="return-link">🔝 Return to Index Matrix</a>
        </div>
    </div>

    <!-- DISCARD COLOUR [x 3] -->
    <div id="discard-colour">
        <div class="rules-box">
            <h2>DISCARD COLOUR [x 3]:</h2>
            <div>Normal Class | Group Targeting | User Goes Last</div>
            <div>Play to the side of the Discards [01.5].</div>

            <div class="image-container">
                <img src="/assets/images/cards/00-core-game-discard-colour.png" alt="Discard Colour" />
                <div class="image-caption">Discard Colour Card Template Placeholder</div>
            </div>

            <ol>
                <li>1. Name a Colour used in the game; all Players in Play Order Discard every Card in Their Hand they have of that Colour [01.5].</li>
                <div>Then place this Card on top of the Discards [01.5].</div>
                <li>2. Choose a Colour to continue [01.5].</li>
            </ol>
        </div>
        <div class="return-link-wrapper">
            <a href="#top" class="return-link">🔝 Return to Index Matrix</a>
        </div>
    </div>

    <!-- DISCARD CHAOS CARDS [x 3] -->
    <div id="discard-chaos-cards">
        <div class="rules-box">
            <h2>DISCARD CHAOS CARDS [x 3]:</h2>
            <div>Normal Class | Group Targeting | User Goes Last</div>
            <div>Play to the side of the Discards [01.5].</div>

            <div class="image-container">
                <img src="/assets/images/cards/00-core-game-discard-chaos-cards.png" alt="Discard Chaos Cards" />
                <div class="image-caption">Discard Chaos Cards Card Template Placeholder</div>
            </div>

            <ol>
                <li>1. All Players in Play Order Discard all Chaos Cards in Their Hands [01.5].</li>
                <div class="note-box">
                    <strong>COMPATIBILITY NOTE:</strong> You CANNOT Discard any SOL/OVE/RSE Cards from the Singularity Expansion [01.5].
                </div>
                <div>Then place this Card on top of the Discards [01.5].</div>
                <li>2. Choose a Colour to continue [01.5].</li>
            </ol>
        </div>
        <div class="return-link-wrapper">
            <a href="#top" class="return-link">🔝 Return to Index Matrix</a>
        </div>
    </div>

    <!-- *DOUBLE EDGED [x 2] -->
    <div id="double-edged">
        <div class="rules-box">
            <h2>*DOUBLE EDGED [x 2]:</h2>
