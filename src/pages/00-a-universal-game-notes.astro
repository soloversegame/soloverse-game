            margin: 0 0 15px 0;
            color: var(--text-primary);
            font-size: 1.15rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.02em;
        }
        .matrix-toc-grid {
            list-style: none;
            padding: 0;
            margin: 0;
            display: flex;
            flex-direction: column;
            gap: 12px;
        }
		
		/* Hierarchical Indentation Modifiers inside the Matrix Grid */
        .matrix-item-heading { padding-left: 0px; font-weight: 700; }
        .matrix-item-subheading { padding-left: 15px; font-weight: 600; }
        .matrix-item-card { padding-left: 30px; font-weight: 500; font-style: italic; }

        .matrix-link {
            color: var(--text-muted);
            text-decoration: none;
            transition: color 0.15s;
        }
        .matrix-link:hover {
            color: var(--color-link);
            text-decoration: underline;
        }

        /* Bottom Step Jump Elements */
        .return-link-wrapper {
            text-align: right;
            margin-top: -5px;
            margin-bottom: 35px;
        }
        .return-link {
            color: var(--color-link);
            text-decoration: none;
            font-size: 0.9rem;
            font-weight: 600;
        }
        .return-link:hover {
            text-decoration: underline;
        }

        /* ==========================================================================
           8. UNIFIED MEDIA ENGINE & VISUAL CARD GRIDS
           ========================================================================== */
        .image-container {
            margin: 20px auto;
            padding: 12px;
            background: var(--bg-main-box);
            border: 1px solid var(--text-divider);
            border-radius: 8px;
            text-align: center;
            max-width: 100%;
        }
        .image-container img {
            max-width: 100%;
            max-height: 450px;
            width: auto;
            height: auto;
            object-fit: contain;
            border-radius: 6px;
            display: block;
            margin: 0 auto;
            border: 1px solid var(--text-divider);
        }
        .image-caption {
            font-size: 0.85rem;
            color: var(--text-muted);
            margin-top: 10px;
            font-weight: 500;
            line-height: 1.4;
        }

        /* Horizontal Layout Row Wrapper (Flex Grid Modifiers) */
        .image-row-container {
            display: flex;
            flex-wrap: wrap;
            gap: 15px;
            justify-content: center;
            margin: 20px 0;
            width: 100%;
        }
        .image-row-container .image-container {
            flex: 1 1 calc(33.333% - 15px);
            min-width: 220px;
            margin: 0;
        }

        /* Border Color Coatings for Core and Extension Cards */
        .image-container.border-steel { border: 3px solid #1d4ed8; }
        .image-container.border-poison-core { border: 3px solid #6b21a8; }
        .image-container.border-venom-core { border: 3px solid #dc2626; }
        .image-container.border-carbon { border: 3px solid #ea580c; }
        .image-container.border-stinger-core { border: 3px solid #eab308; }
        .image-container.border-toxin-core { border: 3px solid #16a34a; }
        .image-container.border-diamond { border: 3px solid #3b82f6; }
        .image-container.border-emerald { border: 3px solid #10b981; }
        .image-container.border-redwood { border: 3px solid #5c4033; }
        .image-container.border-oak { border: 3px solid #b58900; }
        .image-container.border-rose { border: 3px solid #ec4899; }
        .image-container.border-amethyst { border: 3px solid #8b5cf6; }
        .image-container.border-stone { border: 3px solid #6b7280; }
    </style>
</head>
