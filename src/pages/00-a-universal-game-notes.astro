---
// src/pages/universal-game-notes.astro
// Premium, native web text universal game notes
---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <!-- Permanent Cache-Busting Network Headers -->
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate" />
    <meta http-equiv="Pragma" content="no-cache" />
    <meta http-equiv="Expires" content="0" />

    <title>Soloverse Universal Game Notes</title>
    <style>
        :root {
            --bg-main: #0f1015;
            --bg-card: #171922;
            --text-primary: #ffffff;
            --text-secondary: #f3f4f6;
            --text-muted: #9ca3af;
            --text-divider: #2d313f;
            --color-accent: #3b82f6;
        }

        :root[data-theme="light"] {
            --bg-main: #f4f5f7;
            --bg-card: #ffffff;
            --text-primary: #111216;
            --text-secondary: #1f2937;
            --text-muted: #4b5563;
            --text-divider: #d1d5db;
            --color-accent: #1d4ed8;
        }

        body {
            font-family: system-ui, -apple-system, sans-serif;
            background: var(--bg-main);
            color: var(--text-secondary);
            max-width: 750px;
            margin: 40px auto;
            padding: 20px;
            line-height: 1.7;
            transition: background 0.3s, color 0.3s;
        }
        .back-link {
            display: inline-block;
            color: var(--color-accent);
            text-decoration: none;
            font-weight: 700;
            margin-bottom: 25px;
            transition: color 0.15s;
        }
        .back-link:hover { color: var(--text-primary); }
        h1 { font-size: 2.3rem; color: var(--text-primary); margin-bottom: 5px; font-weight: 800; letter-spacing: -0.03em; }
        .meta-tag { color: var(--text-muted); font-size: 0.95rem; margin-bottom: 40px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; }
        
        /* Index Jump Matrix */
        .toc-box { 
            background: var(--bg-card); 
            border: 1px solid var(--text-divider); 
            padding: 24px; 
            border-radius: 12px; 
            margin: 30px 0; 
        }
        .toc-title { margin: 0 0 15px 0; color: var(--text-primary); font-size: 1.1rem; font-weight: 700; }
        .toc-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 10px; }
        .toc-link { color: var(--text-muted); text-decoration: none; font-weight: 600; transition: color 0.15s; }
        .toc-link:hover { color: var(--color-accent); }

        h2 { font-size: 1.5rem; color: var(--text-primary); margin-top: 50px; border-bottom: 1px solid var(--text-divider); padding-bottom: 8px; font-weight: 700; }
        h3 { font-size: 1.15rem; color: var(--text-primary); margin-top: 25px; font-weight: 700; }
        p { color: var(--text-secondary); margin: 16px 0; }
        
        /* Game Grid Contents styling */
        .expansion-grid { display: flex; flex-direction: column; gap: 10px; margin: 20px 0; }
        .expansion-row { background: var(--bg-card); border: 1px solid var(--text-divider); padding: 12px 16px; border-radius: 8px; display: flex; align-items: center; justify-content: space-between; gap: 15px; }
        .expansion-name { font-weight: 700; color: var(--text-primary); font-size: 0.95rem; text-transform: uppercase; letter-spacing: 0.02em; }
        .expansion-desc { font-weight: 500; color: var(--text-muted); font-size: 0.9rem; text-align: right; }
    </style>
</head>
<body id="top">

    <a href="/" class="back-link">📂 Return to Shelf Deck</a>

    <h1>SOLOVERSE [UNIVERSAL GAME NOTES]</h1>
    <div class="meta-tag">👥 Ages 7+, 3-10 Players • v2.0.0</div>

    <!-- INDEX JUMP MATRIX -->
    <div class="toc-box">
        <div class="toc-title">📋 Index Jump Matrix</div>
        <ul class="toc-list">
            <li><a href="#contents" class="toc-link">1. Complete Game Contents</a></li>
            <li><a href="#recommendations" class="toc-link">2. First Play Recommendations</a></li>
            <li><a href="#notes" class="toc-link">3. Important Notes</a></li>
            <li><a href="#definitions" class="toc-link">4. Turn Overview Definitions</a></li>
        </ul>
    </div>

    <!-- SECTION 1: GAME CONTENTS -->
    <h2 id="contents">1. Complete Game Contents</h2>
    <p>The total asset vault of the Soloverse tabletop landscape consists of the following baseline card divisions and functional modules:</p>
    
    <div class="expansion-grid">
        <div class="expansion-row">
            <span class="expansion-name">📦 Core Game</span>
            <span class="expansion-desc">[5 x Colours & Basic Chaos Cards]</span>
        </div>
        <div class="expansion-row">
            <span class="expansion-name">📦 Core Extension</span>
            <span class="expansion-desc">[1 x Colour & Moderate Chaos Cards]</span>
        </div>
        <div class="expansion-row">
            <span class="expansion-name">🚀 Core Booster Pack</span>
            <span class="expansion-desc">[Extra Copy of Most Core/Extension Chaos Cards]</span>
        </div>
        <div class="expansion-row">
            <span class="expansion-name">💥 Apocalypse Expansion</span>
            <span class="expansion-desc">[Chaos Draw +2 & +3]</span>
        </div>
        <div class="expansion-row">
            <span class="expansion-name">⚔️ Warzone Expansion</span>
            <span class="expansion-desc">[Chaos Draw +2/+3/+4 Specific Targeted]</span>
        </div>
        <div class="expansion-row">
            <span class="expansion-name">🌋 Devastation Expansion</span>
            <span class="expansion-desc">[Chaos Draw +5/+10]</span>
        </div>
        <div class="expansion-row">
            <span class="expansion-name">🎯 Catastrophe Expansion</span>
            <span class="expansion-desc">[Chaos Draw +5/+10 Specific Targeted]</span>
        </div>
        <div class="expansion-row">
            <span class="expansion-name">🛡️ Oblivion Expansion</span>
            <span class="expansion-desc">[Royal Knights]</span>
        </div>
        <div class="expansion-row">
            <span class="expansion-name">🌀 Singularity Expansion</span>
            <span class="expansion-desc">[SOL / OVE / RSE]</span>
        </div>
        <div class="expansion-row">
            <span class="expansion-name">⚠️ Crisis Expansion</span>
            <span class="expansion-desc">[Crisis]</span>
        </div>
        <div class="expansion-row">
            <span class="expansion-name">☣️ Contagion Expansion</span>
            <span class="expansion-desc">[Super Poison]</span>
        </div>
        <div class="expansion-row">
            <span class="expansion-name">🕊️ Containment Expansion</span>
            <span class="expansion-desc">[Super Mercy]</span>
        </div>
        <div class="expansion-row">
            <span class="expansion-name">🔄️ Contingency I Expansion</span>
            <span class="expansion-desc">[Discard Specific Colour]</span>
        </div>
        <div class="expansion-row">
            <span class="expansion-name">🎨 Coloured Extensions</span>
            <span class="expansion-desc">[7 x Colour Sets]</span>
        </div>
        <div class="expansion-row">
            <span class="expansion-name">🔄 Contingency II Expansion</span>
            <span class="expansion-desc">[Discard New Specific Colours]</span>
        </div>
        <div class="expansion-row">
            <span class="expansion-name">💀 Doomsday Expansion</span>
            <span class="expansion-desc">[Assassination & Regeneration]</span>
        </div>
        <div class="expansion-row">
            <span class="expansion-name">📜 Cataclysm Expansion</span>
            <span class="expansion-desc">[Ancient Stones]</span>
        </div>
        <div class="expansion-row">
            <span class="expansion-name">🏟️ Field Deck</span>
            <span class="expansion-desc">[Rule Changes]</span>
        </div>
    </div>

    <div style="text-align: right; margin-top: 15px;">
        <a href="#top" style="color: var(--color-accent); text-decoration: none; font-size: 0.88rem; font-weight: 700;">🔝 Return to Index Matrix</a>
    </div>

    <!-- SECTION 2: RECOMMENDATIONS -->
    <h2 id="recommendations">2. First Play Recommendations</h2>
    
    <div style="background: var(--bg-card); border: 1px solid var(--text-divider); padding: 24px; border-radius: 12px; margin: 20px 0; display: flex; flex-direction: column; gap: 20px;">
        <p style="margin: 0; font-size: 1rem; color: var(--text-secondary);">
            1. For new Players only use the Core Game Cards for a best First Play Experience.
        </p>

        <div style="border-top: 1px solid var(--text-divider); padding-top: 15px;">
            <p style="margin: 0 0 10px 0; font-size: 1rem; color: var(--text-secondary);">
                2. Next, if you own the Core Extension, know that while it isn’t advised to use these Cards during someone’s First Play, the following Limited Selection of Cards could be added if desired:
            </p>
            <ul style="margin: 0; padding-left: 20px; font-size: 0.95rem; color: var(--text-muted); display: flex; flex-direction: column; gap: 8px;">
                <li>All Orange Number &amp; Action Class Cards. Some Chaos Card’s Icons [such as Discard Colour] can become confusing if a Colour is missing; so, while I would not recommend using these to start with, if this confusion does become an issue, feel free to add them in.</li>
                <li>Some Chaos Cards from the Core Extension you might also consider using are: Badge Collector [x 2], Black Hole, Paradigm Shift, United We Fall, Vaccine &amp; White Hole.</li>
            </ul>
            <div style="margin-top: 12px; background: var(--bg-main); padding: 10px 14px; border-radius: 6px; border-left: 3px solid var(--text-muted); font-size: 0.9rem; font-weight: 600; color: var(--text-secondary);">
                NOTE: These Chaos Cards are far simpler than most in the Core Extension, and therefore can be easier to use.
            </div>
        </div>

        <div style="border-top: 1px solid var(--text-divider); padding-top: 15px;">
            <p style="margin: 0 0 8px 0; font-size: 1rem; color: var(--text-secondary);">
                3. It also isn’t advised to use any of the Optional Expansion Packs for your first few games.
            </p>
            <ul style="margin: 0; padding-left: 20px; font-size: 0.95rem; color: var(--text-muted);">
                <li>For the most part, Expansions are more complicated than those included in the Core Game, excluding them keeps things simple while the new Players get the hang of things.</li>
            </ul>
        </div>

        <p style="margin: 0; border-top: 1px solid var(--text-divider); padding-top: 15px; font-size: 1rem; color: var(--text-secondary);">
            4. Once everyone has got a feel for the game you may up the action with the complete Core Extension.
        </p>

        <p style="margin: 0; border-top: 1px solid var(--text-divider); padding-top: 15px; font-size: 1rem; color: var(--text-secondary);">
            5. Then the next step as you get accustomed to the game play is going all out with a couple of Expansions. Speaking of which, the first one I would especially recommend adding is the Fan Favourite: Apocalypse Expansion.
        </p>
    </div>

    <!-- Anchor Link to jump straight back to the upper index panel -->
    <div style="text-align: right; margin-top: 15px;">
        <a href="#top" style="color: var(--color-accent); text-decoration: none; font-size: 0.88rem; font-weight: 700;">🔝 Return to Index Matrix</a>
    </div>

    <!-- SECTION 3: IMPORTANT NOTES (PART 1 OF 2) -->
    <h2 id="notes">3. Important Notes</h2>
    
    <div style="display: flex; flex-direction: column; gap: 20px; margin: 25px 0;">
        
        <!-- NOTE 1 -->
        <div style="background: rgba(239, 68, 68, 0.05); border: 1px solid rgba(239, 68, 68, 0.15); padding: 20px; border-radius: 12px; border-left: 4px solid #ef4444;">
            <p style="margin: 0 0 10px 0; font-size: 1rem; color: var(--text-secondary); font-weight: 600;">
                1. Never Re-Shuffle the Discards into the Deck as this has the potential for the game to not end.
            </p>
            <ul style="margin: 0 0 10px 0; padding-left: 20px; font-size: 0.95rem; color: var(--text-muted); list-style-type: disc;">
                <li>If the Deck runs out of Drawable Cards, the Game Ends and everyone loses! [e.g.: (01-A) Soloverse (Crazy 8's) (Game Rulebook): Victory Conditions: Rule 5].</li>
            </ul>
            <div style="background: var(--bg-main); padding: 10px 14px; border-radius: 6px; font-size: 0.9rem; font-weight: 600; color: var(--text-secondary);">
                TIP: “The Recycle Chaos Card from the Core Extension can give you options here.”
            </div>
        </div>

        <!-- NOTE 2 -->
        <div style="background: var(--bg-card); border: 1px solid var(--text-divider); padding: 20px; border-radius: 12px;">
            <p style="margin: 0 0 10px 0; font-size: 1rem; color: var(--text-secondary); font-weight: 600;">
                2. There is a difference between Deal Effects and Draw Effects:
            </p>
            <ul style="margin: 0; padding-left: 20px; font-size: 0.95rem; color: var(--text-muted); display: flex; flex-direction: column; gap: 8px; list-style-type: disc;">
                <li>All Deal Effects [including the initial Deal] ignore all Trap Effects [return them to the Deck if Revealed].</li>
                <li>All Draw Effects follow Trap Effects.</li>
            </ul>
        </div>

        <!-- NOTE 3 -->
        <div style="background: var(--bg-card); border: 1px solid var(--text-divider); padding: 20px; border-radius: 12px;">
            <p style="margin: 0 0 6px 0; font-size: 1rem; color: var(--text-secondary); font-weight: 600;">
                3. In some cases, Card Effects can Override and/or Delay others.
            </p>
            <p style="margin: 0 12px 12px 12px; font-size: 0.95rem; color: var(--text-muted);">
                • When this happens, the last Card Always takes Priority.
            </p>
            <div style="display: flex; flex-direction: column; gap: 10px; font-size: 0.92rem; background: var(--bg-main); padding: 14px; border-radius: 8px; border-left: 3px solid var(--color-accent);">
                <strong style="color: var(--text-primary); display: block; text-transform: uppercase; font-size: 0.8rem; letter-spacing: 0.05em;">EXAMPLES:</strong>
                <div style="color: var(--text-secondary);">o If the Stun Chaos Card is in play and Vaccine is played, the Stun Chaos Card cannot Deactivate [and Stun its target’s turn] until Vaccine has finished.</div>
                <div style="color: var(--text-secondary);">o If the Vaccine Chaos Card is in play and its User’s turn is Skipped, the Vaccine Chaos Card cannot Deactivate [allowing Chaos Cards to be played/activated again] due to its User not having a Playable Turn that round.</div>
            </div>
        </div>

        <!-- NOTE 4 -->
        <div style="background: var(--bg-card); border: 1px solid var(--text-divider); padding: 20px; border-radius: 12px;">
            <p style="margin: 0 0 10px 0; font-size: 1rem; color: var(--text-secondary); font-weight: 600;">
                4. Playable Turn Notes:
            </p>
            <ul style="margin: 0 0 12px 0; padding-left: 20px; font-size: 0.95rem; color: var(--text-muted); display: flex; flex-direction: column; gap: 8px; list-style-type: disc;">
                <li>A Playable Turn describes a Turn that the Player can choose for themselves what Card to play.</li>
                <li>A Playable Turn does not describe a Turn where a Player is facing Card Effects.</li>
            </ul>
            <div style="font-size: 0.92rem; background: var(--bg-main); padding: 12px; border-radius: 8px; border-left: 3px solid var(--color-accent); color: var(--text-secondary);">
                <strong>EXAMPLE:</strong> Such as having their Turn Skipped or needing to Respond in Kind to Stacked Draw Effects.
            </div>
        </div>

        <!-- NOTE 5 -->
        <div style="background: var(--bg-card); border: 1px solid var(--text-divider); padding: 20px; border-radius: 12px;">
            <p style="margin: 0 0 10px 0; font-size: 1rem; color: var(--text-secondary); font-weight: 600;">
                5. Turn Order x Discard Timing:
            </p>
            <p style="margin: 0 0 12px 12px; font-size: 0.95rem; color: var(--text-muted);">
                • It is important to follow the Turn Order when such events like Group Discarding occurs.
            </p>
            <div style="display: flex; flex-direction: column; gap: 12px; font-size: 0.92rem; background: var(--bg-main); padding: 14px; border-radius: 8px; border-left: 3px solid var(--color-accent);">
                <strong style="color: var(--text-primary); display: block; text-transform: uppercase; font-size: 0.8rem; letter-spacing: 0.05em;">EXAMPLES:</strong>
                <div>
                    <div style="color: var(--text-secondary); margin-bottom: 4px;">o Playing the Discard Chaos Cards Chaos Card when you only have Chaos Cards left and you expect to win. Technically, in most cases, the User is last to Discard. Meaning, another Player could Discard their Chaos Cards and beat you to the Win.</div>
                    <div style="background: var(--bg-card); padding: 8px 12px; border-radius: 6px; font-size: 0.85rem; font-weight: 600; color: var(--text-secondary); display: inline-block; margin-left: 10px;">
                        TIP: “Unless someone else who hasn’t had to Discard yet still has an Anti-Fun Chaos Card.”
                    </div>
                </div>
                <div style="color: var(--text-secondary);">o Chaos Cards that force all Players to Group Discard 1 more Cards. Observing the Turn Order grants the last Player [in most cases the User] the advantage to choose the Card that continues play.</div>
            </div>
        </div>

        <!-- NOTE 6 -->
        <div style="background: var(--bg-card); border: 1px solid var(--text-divider); padding: 20px; border-radius: 12px;">
            <p style="margin: 0 0 10px 0; font-size: 1rem; color: var(--text-secondary); font-weight: 600;">
                6. Trap Class Chaos Card Notes: 
            </p>
            <ul style="margin: 0; padding-left: 20px; font-size: 0.95rem; color: var(--text-muted); display: flex; flex-direction: column; gap: 8px; list-style-type: disc;">
                <li>All are Dual-Sided and therefore appear Face-Up in the Deck when Shuffled.</li>
                <li>When revealed, remove it from the Deck temporarily and follow its Effects.</li>
                <li>All are Reshuffled back into the Deck after all Effects have been resolved.</li>
                <li>If any are revealed while Dealing [including during the initial Flip to form the Discards], return them randomly to the Deck.</li>
                <li>Some have Instant Effects that can be actioned upon without removing it from the Deck first [e.g.: Mercy] and therefore prevent additional Trap Class Chaos Cards from being Activated.</li>
                <li>All Trap Class Chaos Cards CANNOT be Countered, unless specified [including Trap Class Chaos Cards from Expansions].</li>
            </ul>
        </div>

        <!-- NOTE 7 -->
        <div style="background: var(--bg-card); border: 1px solid var(--text-divider); padding: 20px; border-radius: 12px;">
            <p style="margin: 0 0 10px 0; font-size: 1rem; color: var(--text-secondary); font-weight: 600;">
                7. Multiple Trap Class Chaos Card Activations:
            </p>
            <ul style="margin: 0; padding-left: 20px; font-size: 0.95rem; color: var(--text-muted); display: flex; flex-direction: column; gap: 8px; list-style-type: disc;">
                <li>If multiple Trap Class Chaos Cards are triggered during Drawing, place the latest Trap Class Chaos Card on top of the previous and complete its Effects first.</li>
                <li>Place each Trap Class Chaos Card in a separate “used pile” as their Effects are finalised before returning to the previous Trap Class Chaos Card.</li>
                <li>Then Shuffle all Trap Class Chaos Cards back into the Deck once all Effects have been finalised.</li>
            </ul>
        </div>

        <!-- NOTE 8 -->
        <div style="background: var(--bg-card); border: 1px solid var(--text-divider); padding: 20px; border-radius: 12px;">
            <p style="margin: 0 0 10px 0; font-size: 1rem; color: var(--text-secondary); font-weight: 600;">
                8. Some Cards have Secondary Effect Icons:
            </p>
            <p style="margin: 0 0 12px 12px; font-size: 0.95rem; color: var(--text-muted);">
                • Their details will list these Effects First, in Order of Priority and Second, in the Order they Happen.
            </p>
            <div style="display: flex; flex-direction: column; gap: 12px; font-size: 0.92rem; background: var(--bg-main); padding: 14px; border-radius: 8px; border-left: 3px solid var(--color-accent); margin-bottom: 10px;">
                <strong style="color: var(--text-primary); display: block; text-transform: uppercase; font-size: 0.8rem; letter-spacing: 0.05em;">EXAMPLE:</strong>
                <div style="color: var(--text-secondary);">In the case of the Chaos Draw +4 Reverse Chaos Card, the Draw +4 Effect is the Primary Effect, while the Reverse Effect happens first.</div>
            </div>
            <ul style="margin: 0 0 12px 0; padding-left: 20px; font-size: 0.95rem; color: var(--text-muted); display: flex; flex-direction: column; gap: 8px; list-style-type: disc;">
                <li>After the Direction of Play Reverses, the previous Player must deal with the Primary Draw Effect by Drawing or Responding in Kind.</li>
                <li>However, once the Primary Draw Effect has been resolved, the next Player can act upon the Secondary Reverse Effect.</li>
            </ul>
            <div style="font-size: 0.92rem; background: var(--bg-main); padding: 12px; border-radius: 8px; border-left: 3px solid var(--color-accent); color: var(--text-secondary);">
                <strong>EXAMPLE:</strong> Even if the Chaos Draw +4 Reverse was called Blue, the next Player can play any Coloured Reverse.
            </div>
        </div>

        <!-- NOTE 9 -->
        <div style="background: var(--bg-card); border: 1px solid var(--text-divider); padding: 20px; border-radius: 12px;">
            <p style="margin: 0 0 10px 0; font-size: 1rem; color: var(--text-secondary); font-weight: 600;">
                9. Counter Class Chaos Card Levels:
            </p>
            <ul style="margin: 0 0 12px 0; padding-left: 20px; font-size: 0.95rem; color: var(--text-muted); display: flex; flex-direction: column; gap: 8px; list-style-type: disc;">
                <li>Each Counter Class Chaos Card will have its own Level [e.g.: Lv1, Lv3, etc].</li>
                <li>With some exceptions, any Counter Class Chaos Card CAN be Countered back at you, IF the Responding Counter Class Chaos Card is the Same Level or Higher.</li>
            </ul>
            <div style="display: flex; flex-direction: column; gap: 10px; font-size: 0.92rem; background: var(--bg-main); padding: 14px; border-radius: 8px; border-left: 3px solid var(--color-accent); margin-bottom: 12px;">
                <strong style="color: var(--text-primary); display: block; text-transform: uppercase; font-size: 0.8rem; letter-spacing: 0.05em;">EXAMPLE:</strong>
                <p style="margin: 0 0 6px 0; color: var(--text-secondary);">Compare Nou [a Lv2 Counter Class Chaos Card from the Core Game] and Not Me [a Lv3 Counter Class Chaos Card from the Core Extension].</p>
                <div style="color: var(--text-secondary); padding-left: 10px;">o Not Me [Lv3] CAN Counter Itself &amp; Nou [Lv2].</div>
                <div style="color: var(--text-secondary); padding-left: 10px;">o Whereas Nou [Lv2] CAN Counter Itself but CANNOT Counter Not Me [Lv3].</div>
            </div>
            <p style="margin: 0 0 12px 12px; font-size: 0.95rem; color: var(--text-muted);">
                • Keep in mind that there are Specifically Countered situations that contradict this Important Note.
            </p>
            <div style="font-size: 0.92rem; background: rgba(255, 242, 0, 0.05); padding: 14px; border-radius: 8px; border-left: 3px solid #fff200; color: var(--text-secondary);">
                <strong>EXAMPLE:</strong> Anti-Fun [a Level 1 Counter Class Chaos Card from the Core Game]. Despite all other Counter Class Chaos Cards having a higher Level, only Nou can Counter Anti-Fun if played as your last Card.
            </div>
        </div>

    </div>

    <!-- Anchor Link to jump straight back to the upper index panel -->
    <div style="text-align: right; margin-top: 15px; margin-bottom: 30px;">
        <a href="#top" style="color: var(--color-accent); text-decoration: none; font-size: 0.88rem; font-weight: 700;">🔝 Return to Index Matrix</a>
    </div>

    <!-- SECTION 4: TURN OVERVIEW DEFINITIONS -->
    <h2 id="definitions">4. Turn Overview Definitions</h2>
    <p style="font-style: italic; color: var(--text-muted); margin-bottom: 25px;">
        “These Turn Overview Definitions will almost never be needed, but in instances where disputes arise, they will come in Handy”.
    </p>

    <div style="display: flex; flex-direction: column; gap: 24px; margin: 25px 0;">
        
        <!-- OPENING PHASE -->
        <div style="background: var(--bg-card); border: 1px solid var(--text-divider); padding: 24px; border-radius: 12px; border-left: 4px solid #3b82f6;">
            <strong style="color: var(--text-primary); font-size: 1.25rem; display: block; margin-bottom: 6px;">🌅 Opening Phase</strong>
            <p style="margin: 0 0 12px 0; font-size: 0.95rem; color: var(--text-secondary);">
                <strong>Definition:</strong> After the previous Player’s End Phase, but before your turn actually starts.
            </p>
            
            <div style="display: flex; flex-direction: column; gap: 12px; border-top: 1px solid var(--text-divider); padding-top: 16px;">
                <strong style="color: var(--text-primary); font-size: 0.9rem; text-transform: uppercase; tracking: 0.05em; display: block;">Required For:</strong>
                <div>
                    <strong style="color: var(--text-primary); font-size: 0.95rem; display: block; margin-bottom: 4px;">1. Carry Over Effects:</strong>
                    <p style="margin: 0 0 8px 0; font-size: 0.9rem; color: var(--text-muted);">Some Card Effects Carry Over between Player's Turns and Activate during the Opening Phase of the next Player’s Turn [“As in you face them before your turn actually starts”].</p>
                    <div style="background: var(--bg-main); padding: 10px 14px; border-radius: 6px; font-size: 0.88rem; color: var(--text-secondary); border-left: 2px solid #3b82f6;">
                        <strong>EXAMPLE:</strong> Draw +2 &amp; Chaos Draw +4 from the Core Game.
                    </div>
                </div>
                <div>
                    <strong style="color: var(--text-primary); font-size: 0.95rem; display: block; margin-bottom: 4px;">2. Activate Before Starting Your Turn:</strong>
                    <p style="margin: 0 0 8px 0; font-size: 0.9rem; color: var(--text-muted);">Certain Chaos Cards activate in the Opening Phase if they state: Activate before you start a Playable Turn. Your turn’s Main Phase only starts after such Chaos Cards’ Effects are activated.</p>
                    <div style="background: var(--bg-main); padding: 10px 14px; border-radius: 6px; font-size: 0.88rem; color: var(--text-secondary); border-left: 2px solid #3b82f6;">
                        <strong>EXAMPLE:</strong> A lot of Expansion Chaos Cards use this Effect such as the Royal Knight Class Jack’s Knight from the Oblivion Expansion. It changes the rules for your Main Phase, allowing 2 playable Cards to be played instead of just 1.
                    </div>
                </div>
            </div>
        </div>

        <!-- MAIN PHASE -->
        <div style="background: var(--bg-card); border: 1px solid var(--text-divider); padding: 24px; border-radius: 12px; border-left: 4px solid #10b981;">
            <strong style="color: var(--text-primary); font-size: 1.25rem; display: block; margin-bottom: 6px;">⚔️ Main Phase</strong>
            <p style="margin: 0; font-size: 0.95rem; color: var(--text-secondary);">
                <strong>Definition:</strong> Basically, your actual Turn; the Card or Cards you play.
            </p>
        </div>

        <!-- END PHASE -->
        <div style="background: var(--bg-card); border: 1px solid var(--text-divider); padding: 24px; border-radius: 12px; border-left: 4px solid #f59e0b;">
            <strong style="color: var(--text-primary); font-size: 1.25rem; display: block; margin-bottom: 6px;">🌌 End Phase</strong>
            <p style="margin: 0 0 12px 0; font-size: 0.95rem; color: var(--text-secondary);">
                <strong>Definition:</strong> The last step in your turn; it sits between your Main Phase and the next Player’s Opening Phase.
            </p>
            
            <div style="display: flex; flex-direction: column; gap: 14px; border-top: 1px solid var(--text-divider); padding-top: 16px;">
                <strong style="color: var(--text-primary); font-size: 0.9rem; text-transform: uppercase; tracking: 0.05em; display: block;">Required For:</strong>
                <div>
                    <strong style="color: var(--text-primary); font-size: 0.95rem; display: block; margin-bottom: 4px;">1. Effect Finalisation:</strong>
                    <p style="margin: 0 0 8px 0; font-size: 0.9rem; color: var(--text-muted);">The last step in your turn after playing a Card.</p>
                    <div style="background: var(--bg-main); padding: 10px 14px; border-radius: 6px; font-size: 0.88rem; color: var(--text-secondary); border-left: 2px solid #f59e0b;">
                        <strong>EXAMPLE:</strong> After activating a Chaos Card, you will usually need to Choose a Colour to Continue, and this designates the start of your End Phase.
                    </div>
                </div>
                <div>
                    <strong style="color: var(--text-primary); font-size: 0.95rem; display: block; margin-bottom: 4px;">2. Victory Conditions:</strong>
                    <p style="margin: 0 0 8px 0; font-size: 0.9rem; color: var(--text-muted);">Victory Conditions are checked during this Phase.</p>
                    <div style="display: flex; flex-direction: column; gap: 8px; background: var(--bg-main); padding: 12px; border-radius: 8px; font-size: 0.88rem; border-left: 2px solid #f59e0b; color: var(--text-secondary);">
                        <strong style="color: var(--text-primary); display: block; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em;">EXAMPLES:</strong>
                        <div>• The main Victory Condition is having No Cards Left [e.g.: (01-A) Soloverse (Crazy 8's) (Game Rulebook): Victory Conditions: Rule 2].</div>
                        <div>• If your last Card has a Draw Effect, Play continues until a Player is forced to Draw. [e.g.: (01-A) Soloverse (Crazy 8's) (Game Rulebook): Victory Conditions: Rule 3]. Until that happens, you cannot complete your Victory Condition of No Cards Left.</div>
                    </div>
                </div>
                <div>
                    <strong style="color: var(--text-primary); font-size: 0.95rem; display: block; margin-bottom: 4px;">3. Chaos Card Activation:</strong>
                    <p style="margin: 0 0 8px 0; font-size: 0.9rem; color: var(--text-muted);">“Most cards do not use this, but one does come to mind.”</p>
                    <div style="background: var(--bg-main); padding: 12px; border-radius: 8px; font-size: 0.88rem; border-left: 2px solid #f59e0b; color: var(--text-secondary);">
                        <strong>EXAMPLE:</strong> That example is the Counter Class Chaos Card: Anti-Fun, from the Core Game. It is technically during your End Phase, in response to your Victory Condition of No Cards Left, that any Opponent can use it to force you to Deal 5 extra Cards to yourself. At this point, your Victory Condition checks for No Cards Left, finds Cards and cancels itself, completing your Turn’s End Phase.
                    </div>
                </div>
                <div>
                    <strong style="color: var(--text-primary); font-size: 0.95rem; display: block; margin-bottom: 4px;">4. Carry Over Effects:</strong>
                    <p style="margin: 0; font-size: 0.9rem; color: var(--text-muted);">Many Effects are forwarded onto the next Player’s Opening Phase [see: Opening Phase above].</p>
                </div>
            </div>
        </div>

    </div>

    <!-- Anchor Link to jump straight back to the upper index panel -->
    <div style="text-align: right; margin-top: 15px;">
        <a href="#top" style="color: var(--color-accent); text-decoration: none; font-size: 0.88rem; font-weight: 700;">🔝 Return to Index Matrix</a>
    </div>

    <!-- Soloverse Rulebook Page Engine: Auto-Theme Detection & Update Sync -->
    <script is:inline>
        (function() {
            // 1. SERVICE WORKER REVALIDATION
            if ('serviceWorker' in navigator) {
                navigator.serviceWorker.getRegistrations().then(function(registrations) {
                    for (let registration of registrations) {
                        registration.update(); 
                    }
                });
            }

            // 2. AUTOMATED THEME EVALUATION (User Override vs System Preference)
            const savedTheme = localStorage.getItem('soloverse-theme');
            const devicePrefersDarkMode = window.matchMedia('(prefers-color-scheme: dark)').matches;
            
            let activeTheme = 'dark'; // Base anchor default fallback

            if (savedTheme) {
                // Priority 1: Respect explicit button clicks from the main bookshelf hub
                activeTheme = savedTheme;
            } else {
                // Priority 2: Auto-adopt the tablet/device's native operating system mode
                activeTheme = devicePrefersDarkMode ? 'dark' : 'light';
            }

            // Mount theme instantly to root document element
            document.documentElement.setAttribute('data-theme', activeTheme);
        })();
    </script>
</body>
</html>
