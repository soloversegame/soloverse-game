        }
        .hub-link-button:hover {
            background: var(--text-divider);
            color: var(--text-primary);
            transform: translateY(-1px);
        }

        /* Index Jump Matrix Table Container */
        .matrix-toc-box {
            background: var(--bg-card);
            border: 1px solid var(--text-divider);
            padding: 24px;
            border-radius: 12px;
            margin: 30px 0;
