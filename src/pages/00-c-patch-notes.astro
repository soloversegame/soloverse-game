---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <!-- Permanent Cache-Busting Network Headers -->
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate" />
    <meta http-equiv="Pragma" content="no-cache" />
    <meta http-equiv="Expires" content="0" />

    <title>Soloverse Rulebook Patch Notes</title>
    <style>
        /* ==========================================
           ISOLATED VIEWPORT OVERRIDE ENGINE
           ========================================== */

        /* 1. When portrait, the rotation container acts completely transparently */
        .rotation-viewport-wrapper {
            width: 100%;
            height: auto;
        }

        /* 2. When rotated, we lock the HTML frame and let the inner wrapper handle smooth touch scrolling */
        html[data-rotate-override="landscape"] {
            overflow: hidden !important;
            position: fixed;
            width: 100vw;
            height: 100vh;
        }

        html[data-rotate-override="landscape"] body {
            margin: 0 !important;
            padding: 0 !important;
            max-width: none !important;
            width: 100vw !important;
            height: 100vh !important;
            overflow: hidden !important;
        }

        html[data-rotate-override="landscape"] .rotation-viewport-wrapper {
            transform: rotate(90deg);
            transform-origin: top left;
            position: absolute;
            top: 0;
            left: 100vw;
            width: 100vh !important;  /* Maps text layout width to use physical phone height */
            height: 100vw !important; /* Maps the scrolling viewport boundary to use physical phone width */
            overflow-x: hidden !important;
            overflow-y: scroll !important; /* Unlocks hardware-accelerated touch physics */
            -webkit-overflow-scrolling: touch; /* Essential iOS Safari / WebKit kinetic touch physics hook */
            padding: 24px 32px 80px 32px;
            box-sizing: border-box;
        }

        /* Force container components to recalculate space fluidly inside the active viewport wrapper */
        html[data-rotate-override="landscape"] .rules-box,
        html[data-rotate-override="landscape"] .note-box,
        html[data-rotate-override="landscape"] table,
        html[data-rotate-override="landscape"] .toc-box {
            width: 100% !important;
            max-width: 100% !important;
            box-sizing: border-box !important;
        }
		
        :root {
            --bg-main: #0f1015;
            --bg-card: #171922;
            --bg-main-box: #1c1e27;
            --text-primary: #ffffff;
            --text-secondary: #f3f4f6;
            --text-muted: #9ca3af;
            --text-divider: #2d313f;
            --color-accent: #3b82f6;
        }

        :root[data-theme="light"] {
            --bg-main: #f4f5f7;
            --bg-card: #ffffff;
            --bg-main-box: #f9fafb;
            --text-primary: #111216;
            --text-secondary: #1f2937;
            --text-muted: #4b5563;
            --text-divider: #d1d5db;
            --color-accent: #1d4ed8;
        }

        body {
            font-family: system-ui, -apple-system, sans-serif;
            background: var(--bg-main);
            color: var(--text-secondary);
            max-width: 750px;
            margin: 40px auto;
            padding: 20px;
            line-height: 1.7;
            transition: background 0.3s, color 0.3s;
        }
        .back-link {
            display: inline-block;
            color: var(--color-accent);
            text-decoration: none;
            font-weight: 700;
            margin-bottom: 25px;
            transition: color 0.15s;
        }
        .back-link:hover { color: var(--text-primary); }
        h1 { font-size: 2.3rem; color: var(--text-primary); margin-bottom: 5px; font-weight: 800; letter-spacing: -0.03em; }
        .meta-tag { color: var(--text-muted); font-size: 0.95rem; margin-bottom: 40px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; }
        
        /* Timeline Log Cards */
        .patch-card {
            background: var(--bg-card);
            border: 1px solid var(--text-divider);
            padding: 24px;
            border-radius: 12px;
            margin-bottom: 25px;
            position: relative;
        }
        .patch-date {
            display: inline-block;
            background: var(--bg-main-box);
            color: var(--text-primary);
            font-weight: 700;
            padding: 4px 12px;
            border-radius: 6px;
            font-size: 0.95rem;
            margin-bottom: 15px;
            border: 1px solid var(--text-divider);
        }
        ul { margin: 0; padding-left: 20px; color: var(--text-secondary); }
        li { margin-bottom: 8px; }
        ul ul { margin-top: 8px; margin-bottom: 0; list-style-type: circle; }
    </style>
</head>
<body id="top">

	<a href="/" class="back-link">📂 Return to Shelf Deck</a>
	<button id="rotate-view-btn" class="rotate-toggle-btn" style="margin-left: 15px;">🔄 Flip View</button>

    <h1>SOLOVERSE - RULEBOOK PATCH NOTES</h1>
    <div class="meta-tag">📜 Balancing Timeline &amp; Architecture Logs • v2.0.0</div>

    <!-- 2026-07-12 -->
    <div class="patch-card" style="border-left: 4px solid var(--color-accent);">
        <div class="patch-date">2026-07-12</div>
        <ul style="list-style-type: disc;">
            <li>Full HTML Website redevelopment in progress</li>
        </ul>
        <p style="margin: 12px 0 4px 20px; font-weight: 700; color: var(--text-primary);">The Rulebook is now split into 3:</p>
        <ul style="list-style-type: circle; padding-left: 40px;">
            <li>Universal Game Notes for all Game Versions</li>
            <li>Individual Games’ Rulebooks</li>
            <li>Individual Games’ Chaos Card Definition Rulebooks</li>
        </ul>
    </div>

    <!-- 2026-05-30 -->
    <div class="patch-card">
        <div class="patch-date">2026-05-30</div>
        <ul style="list-style-type: disc;">
            <li>Small Patch for most current Definition Rulebooks, changing the Contingency I &amp; II Expansion’s Description from All Players in play to All Players in Play Order</li>
            <li>Small Patch for all current Definition Rulebooks, changing the grammar of the term “play order” to “Play Order”</li>
        </ul>
    </div>

    <!-- 2026-05-21 -->
    <div class="patch-card">
        <div class="patch-date">2026-05-21</div>
        <ul style="list-style-type: disc;">
            <li>A lot of Balancing to the [06-A] Soloverse – The Deck-Building Variant.
                <ul style="padding-left: 20px;">
                    <li>Reverse Effects has priority over Skip Effects.</li>
                    <li>Steal Turn now MUST be activated BEFORE any other Player Plays Their first Card.</li>
                    <li>Steal Turn, Reverse Stun, Stun, Discard Chaos Cards all MUST be placed in the Targeted Player’s Discards when finalised.</li>
                    <li>Steal Turn, Reverse Stun and Stun all force the Targeted Player to Discard Their Hand when the Card Effect Finalises and Draw a new Hand.</li>
                    <li>All Chaos Cards with Skip and Reverse Effects [Pure Chaos &amp; Chaos Draw], now also preserve Their Reverse and Skip Effects on top of Their already powerful abilities.</li>
                    <li>Elegant Generosity now allows all Players to Draw 3 Cards each.</li>
                    <li>United We Fall now allows all Players to Draw 2 Cards, then Discard 2 Cards.</li>
                    <li>Double Edged now allows you to Target any Player and Steal a Card from Their Discards and add it to Your Hand. However, They then Steal a Card from Yours.</li>
                    <li>Scavenger now lets You Choose 1 Effect from the following:
                        <ul style="padding-left: 20px; list-style-type: lower-alpha;">
                            <li>Recover any Card from the Scrap Pile and place it in Your Discards.</li>
                            <li>Recover any Card from Your Discards and Gain it to Your Hand.</li>
                            <li>Recover any Card from any other Player’s Discards and place it in Your Discards.</li>
                            <li>Alternatively, “Revive” the Recycle Chaos Card.</li>
                        </ul>
                    </li>
                    <li>2 Game Modes: Short Game [First to their Random Chaos Draw +5] or Long Game [First to the Chaos Draw +10 Specific Targeted.</li>
                    <li>Amongst others…</li>
                </ul>
            </li>
        </ul>
    </div>

    <!-- 2026-05-18 -->
    <div class="patch-card">
        <div class="patch-date">2026-05-18</div>
        <ul style="list-style-type: disc;">
            <li>Universal Formatting across all Rulebooks is slowly being rolled out.</li>
            <li>Changed How to View and Universal Game Notes Files to PDF.</li>
            <li>New Definition clarifications for some Chaos Cards and outright new Effects for others [e.g.: [01-B] Soloverse – Crazy 8’s [Definitions Rulebook] listing for Roulette].</li>
            <li>Introducing: [01-E] Soloverse – Crazy 8’s [Achievements List] ! While still in Development, as you play the game, keep track of certain Card Effects and Combos designed to help you learn the game easier.</li>
            <li>Also Introducing: [06-A] Soloverse – The Deck-Building Variant!</li>
            <li>Almost Ready for Playtesting: [07-A] Soloverse – Nominations [and (due to their game rule similarities) when Nominations is ready, [0?-A] Soloverse – 500 and [0?-A] Soloverse – Poker won’t be far away]</li>
        </ul>
    </div>

    <!-- 2025-06-29 -->
    <div class="patch-card">
        <div class="patch-date">2025-06-29</div>
        <p style="margin: 0 0 8px 0; font-weight: 700; color: var(--text-primary);">New Game Variant: Battle Solitaire!</p>
        <ul style="list-style-type: disc;">
            <li>Playtesting Required, but Game Rules should be good to go</li>
            <li>Definitions may Require Editing…</li>
        </ul>
    </div>

    <!-- 2025-06-21 -->
    <div class="patch-card">
        <div class="patch-date">2025-06-21</div>
        <p style="margin: 0 0 4px 0; font-weight: 700; color: var(--text-primary);">New Game Variant: Crazy 8’s Utter Chaos!</p>
        <p style="margin: 0 0 8px 0; font-weight: 700; color: var(--text-primary);">New Game Variant: Karma!</p>
        <ul style="list-style-type: disc;">
            <li>Playtesting Required, but Game Rules and Definitions should be good to go</li>
        </ul>
        <p style="margin: 12px 0 4px 0; font-weight: 700; color: var(--text-primary);">Major Changes:</p>
        <ul style="list-style-type: circle;">
            <li>Wild Cards are now Called Chaos Cards!</li>
            <li>Updated the How to View and Patch Notes Files to DOCX instead of GDOC for ease of editing</li>
        </ul>
    </div>

    <!-- 2025-06-03 -->
    <div class="patch-card">
        <div class="patch-date">2025-06-03</div>
        <p style="margin: 0 0 4px 0; font-weight: 700; color: var(--text-primary);">Major Changes:</p>
        <ul style="list-style-type: disc;">
            <li>Split Game Rulebook into 2, Game Notes for all Game Variants and a Rulebook for each individual Game Variant</li>
            <li>An Edited Definitions Rulebook for each Game Variant.</li>
        </ul>
    </div>

    <!-- 2024/07/18 -->
    <div class="patch-card">
        <div class="patch-date">2024/07/18</div>
        <p style="margin: 0 0 4px 0; font-weight: 700; color: var(--text-primary);">Major Changes:</p>
        <ul style="list-style-type: disc; margin-bottom: 12px;">
            <li>Added the Contents Page for the Core Game/Extension to the Definitions Rulebook.
                <ul style="padding-left: 20px; list-style-type: circle; margin-top: 4px;">
                    <li>Due to showing the game to a new player personally, we found an issue with the split rulebook where the Action Card Rules felt more natural to be in the Wild Card Definitions not in the Game Rules</li>
                    <li>Due to the order of use of some expansions over others, i have moved the location of the Devastation and Catastrophe Rules to just after (Apocalypse and) Warzone - so Wild Draw 2, 3, 4, 5 &amp; 10 are all grouped together</li>
                </ul>
            </li>
            <li>Clarified the 2 Player Game Note for both Slap and Snap Wild Cards</li>
            <li>Removed some smaller tips and variation notes due to not really needed</li>
            <li>Minor formatting</li>
        </ul>
    </div>

    <!-- 2024/07/10 -->
    <div class="patch-card">
        <div class="patch-date">2024/07/10</div>
        <ul style="list-style-type: disc;">
            <li>Updated Core Extension’s Genetic Manipulation Wild Card Rules to balance for more Expansion options [Finally, Wild Draw +10’s are allowed!! You’ve Won the Draw Stack, but at What Cost?]</li>
            <li>Refined the Crisis Expansion Rules [Finally I feel they work how I wanted them to]</li>
            <li>Formatting Fixes</li>
            <li>Spelling and Grammar Fixes</li>
        </ul>
    </div>

    <!-- 2024/07/07 -->
    <div class="patch-card" style="margin-bottom: 40px;">
        <div class="patch-date">2024/07/07</div>
        <p style="margin: 0 0 8px 0; font-weight: 700; color: var(--text-primary);">NEW GAME MODE: LAST PLAYER STANDING [See WINNING THE GAME: OPTION 3 in the “GAME RULES.pdf”]</p>
        <ul style="list-style-type: disc;">
            <li>Minor Formatting Fixes</li>
        </ul>
    </div>

    <!-- Soloverse Rulebook Page Engine: Auto-Theme Detection & Update Sync -->
    <script is:inline>
        (function() {
            // 1. SERVICE WORKER REVALIDATION
            if ('serviceWorker' in navigator) {
                navigator.serviceWorker.getRegistrations().then(function(registrations) {
                    for (let registration of registrations) {
                        registration.update(); 
                    }
                });
            }

            // 2. AUTOMATED THEME EVALUATION (User Override vs System Preference)
            const savedTheme = localStorage.getItem('soloverse-theme');
            const devicePrefersDarkMode = window.matchMedia('(prefers-color-scheme: dark)').matches;
            
            let activeTheme = 'dark'; // Base anchor default fallback

            if (savedTheme) {
                // Priority 1: Respect explicit button clicks from the main bookshelf hub
                activeTheme = savedTheme;
            } else {
                // Priority 2: Auto-adopt the tablet/device's native operating system mode
                activeTheme = devicePrefersDarkMode ? 'dark' : 'light';
            }

            // Mount theme instantly to root document element
            document.documentElement.setAttribute('data-theme', activeTheme);

			// 3. MANUAL CANVAS ROTATION OVERRIDE CONTROLS
            window.addEventListener('DOMContentLoaded', () => {
                const rotateBtn = document.getElementById('rotate-view-btn');
                if (!rotateBtn) return;

                let currentRotateState = localStorage.getItem('soloverse-rotate-lock') || 'portrait';
                document.documentElement.setAttribute('data-rotate-override', currentRotateState);

                rotateBtn.addEventListener('click', () => {
                    const activeState = document.documentElement.getAttribute('data-rotate-override');
                    const targetState = activeState === 'landscape' ? 'portrait' : 'landscape';
                    
                    document.documentElement.setAttribute('data-rotate-override', targetState);
                    localStorage.setItem('soloverse-rotate-lock', targetState);
                });
            });
        })();
    </script>
</body>
</html>