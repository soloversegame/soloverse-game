---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <!-- Permanent Cache-Busting Network Headers -->
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate" />
    <meta http-equiv="Pragma" content="no-cache" />
    <meta http-equiv="Expires" content="0" />

    <title>Soloverse Rulebook Hub</title>

    <!-- 1. Tell the phone browser exactly where your live app blueprint sits -->
    <link rel="manifest" href="/manifest.webmanifest" />

    <!-- 2. Force the mobile address bar and theme layers to adapt to your dark game profile -->
    <meta name="theme-color" content="#0f1015" />

    <style>
        /* ==========================================================================
           AUTOMATED TABLET & WIDESCREEN RESPONSIVE ENGINE
           ========================================================================== */

        /* Automatically expands text spreads when tablets are flipped horizontally */
        @media screen and (min-width: 768px) and (orientation: landscape) {
            body {
                max-width: 960px; /* Expands reading column limits for a comfortable landscape view */
                margin: 40px auto;
                padding: 0 30px;
            }

            .rules-box {
                padding: 32px;
                margin: 24px 0;
            }
        }

        /* Large Screen Optimizations (Large Tablets, Monitors, and Laptops) */
        @media screen and (min-width: 1024px) {
            body {
                max-width: 1050px; /* Sweeps columns out nicely on large display panels */
            }
        }
		
		/* PWA Installation Overlay Banner Layout */
		.pwa-install-banner {
			position: fixed;
			bottom: 20px;
			left: 50%;
			transform: translateX(-50%);
			width: calc(100% - 40px);
			max-width: 500px;
			background: var(--bg-card);
			border: 1px solid var(--text-divider);
			box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.4);
			border-radius: 12px;
			padding: 16px;
			z-index: 9999;
			display: none; /* Controlled dynamically via runtime scripts */
			flex-direction: column;
			gap: 12px;
			transition: opacity 0.3s ease;
		}

		.pwa-header {
			display: flex;
			align-items: center;
			justify-content: space-between;
		}

		.pwa-title {
			font-weight: 700;
			color: var(--text-primary);
			font-size: 1rem;
		}

		.pwa-close-btn {
			background: none;
			border: none;
			color: var(--text-muted);
			font-size: 1.2rem;
			cursor: pointer;
			padding: 0 4px;
		}

		.pwa-body {
			font-size: 0.9rem;
			color: var(--text-secondary);
			line-height: 1.4;
		}

		.pwa-action-row {
			display: flex;
			justify-content: flex-end;
			gap: 8px;
			margin-top: 4px;
		}

		.pwa-btn {
			padding: 8px 16px;
			border-radius: 6px;
			font-size: 0.85rem;
			font-weight: 600;
			cursor: pointer;
			border: none;
		}

		.pwa-btn-primary {
			background: var(--color-link);
			color: #ffffff;
		}

		.pwa-btn-secondary {
			background: var(--bg-main-box);
			border: 1px solid var(--text-divider);
			color: var(--text-secondary);
		}

		/* Landscape-Specific Media Rules Override */
		@media (orientation: landscape) and (min-width: 768px) {
			body {
				max-width: 1000px; /* Expands rulebook layout limits automatically when flipped horizontally */
				margin: 20px auto;
				padding: 30px;
				display: grid;
				grid-template-columns: 1fr; /* Ensures container blocks adapt smoothly to the extra real estate */
			}

			.rules-box {
				padding: 32px; /* Amplifies grid spacing layouts comfortably for widescreen reading */
			}
		}
		
        /* 1. DEFINE YOUR REACTIVE COLOR MAP ARCHITECTURE */
        :root {
            --bg-main: #0f1015;
            --bg-card: #171922;
            --bg-contents: #1c1e27;
            --bg-link: #242732;
            --bg-link-hover: #2c303f;
            --text-primary: #ffffff;
            --text-secondary: #f3f4f6;
            --text-muted: #9ca3af;
            --text-divider: #2d3139;
            --shadow-card: rgba(0, 0, 0, 0.5);
        }

        /* 2. AUTOMATIC LIGHT MODE OVERRIDE DATA VALUES */
        :root[data-theme="light"] {
            --bg-main: #f4f5f7;
            --bg-card: #ffffff;
            --bg-contents: #f9fafb;
            --bg-link: #f3f4f6;
            --bg-link-hover: #e5e7eb;
            --text-primary: #111216;
            --text-secondary: #1f2937;
            --text-muted: #4b5563;
            --text-divider: #d1d5db;
            --shadow-card: rgba(0, 0, 0, 0.1);
        }

        body {
            font-family: system-ui, -apple-system, sans-serif;
            background: var(--bg-main);
            color: var(--text-secondary);
            max-width: 900px;
            margin: 40px auto;
            padding: 20px;
            transition: background 0.3s, color 0.3s;
        }
        h1 {
            text-align: center;
            color: var(--text-primary);
            font-size: 2.5rem;
            margin-bottom: 5px;
            font-weight: 800;
            letter-spacing: -0.05em;
        }
        .subtitle {
            text-align: center;
            color: var(--text-muted);
            margin-bottom: 50px;
        }
        
        /* 1. BUTTON HOVER CONTAINER FLEXBOX LAYOUT (Add this above your button code) */
        .theme-toggle-container {
            display: flex;
            justify-content: flex-start;
            align-items: center;
            gap: 10px;
            margin-bottom: 25px;
        }

        /* 2. THE CORE BUTTON DESIGN (Keep your custom pill configurations) */
        .theme-btn {
            background: var(--bg-card);
            color: var(--text-primary);
            border: 1px solid var(--text-divider);
            padding: 10px 16px;
            border-radius: 50px; /* Keeps your premium pill design */
            font-weight: 700;
            cursor: pointer;
            font-size: 0.9rem;
            box-shadow: 0 4px 6px -1px var(--shadow-card);
            display: inline-flex; /* Ensures text and emojis center perfectly together */
            align-items: center;
            gap: 8px;
            transition: background 0.2s, color 0.2s, transform 0.1s, border-color 0.2s;
        }

        /* Adds a subtle layout response highlight when hovering over buttons */
        .theme-btn:hover {
            border-color: var(--color-link);
            background: var(--bg-main-box);
        }

        /* 3. ACTIVE CLICK SPRING ANIMATION (Keep this completely intact!) */
        .theme-btn:active { 
            transform: scale(0.97); /* Keeps your tactile push spring effect on click */
        }

        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
            gap: 30px;
        }
        .game-card {
            background: var(--bg-card);
            border-radius: 16px;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            box-shadow: 0 10px 25px -5px var(--shadow-card), 0 8px 10px -6px var(--shadow-card);
            transition: transform 0.2s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.2s;
        }
        .game-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 20px 25px -5px var(--shadow-card), 0 10px 10px -5px var(--shadow-card);
        }
        .game-header {
            padding: 24px 20px;
            position: relative;
        }
        .game-header::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(to bottom, rgba(255,255,255,0.12), rgba(0,0,0,0.35));
        }
        .game-title {
            position: relative;
            z-index: 10;
            margin: 0;
            font-size: 1.15rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.03em;
        }
        .box-contents {
            padding: 20px;
            background: var(--bg-contents);
            flex-grow: 1;
            display: flex;
            flex-direction: column;
            gap: 12px;
            border-top: 1px solid var(--text-divider);
        }
        .links-list {
            display: flex;
            flex-direction: column;
            gap: 8px;
            margin: 0;
            padding: 0;
            list-style: none;
        }
        .rule-link {
            display: flex;
            align-items: center;
            background: var(--bg-link);
            color: var(--text-muted);
            text-decoration: none;
            padding: 12px 14px;
            border-radius: 8px;
            font-weight: 600;
            font-size: 0.9rem;
            border: 1px solid var(--text-divider);
            transition: background 0.15s, color 0.15s, border-color 0.15s;
        }
        .rule-link:hover {
            background: var(--bg-link-hover);
            color: var(--text-primary);
        }
        .section-divider {
            grid-column: 1 / -1;
            margin-top: 60px;
            margin-bottom: 20px;
            border-bottom: 1px dashed var(--text-divider);
            padding-bottom: 15px;
            color: var(--text-muted);
            font-size: 1.25rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }
        .blueprint-card {
            background: var(--bg-card);
            opacity: 0.7;
            border: 2px dashed var(--text-divider);
            border-radius: 16px;
            padding: 24px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            min-height: 120px;
            position: relative;
            overflow: hidden;
        }
        .blueprint-title {
            margin: 0;
            font-size: 1rem;
            font-weight: 700;
            color: var(--text-muted);
        }
        .status-badge {
            align-self: flex-start;
            background: var(--bg-link);
            color: var(--text-muted);
            font-size: 0.7rem;
            font-weight: 700;
            padding: 4px 8px;
            border-radius: 4px;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            margin-top: 15px;
        }
    </style>

</head>
<body>

    <!-- THE REACTIVE THEME & ROTATION OPTION INTERFACE CONTROLLER BUTTONS -->
    <div class="theme-toggle-container">
        <button id="theme-toggle-btn" class="theme-btn">☀️ Light Mode</button>
    </div>
	
    <h1>Soloverse Rulebook Hub</h1>
    <p class="subtitle">Select a Game Variant below to stream live, iOS-friendly interactive document layers.</p>

    <div class="grid">
        {gamesList.map((game) => {
            const titleColor = game.boxColor === "#fff200" ? "#111216" : "#ffffff";
            const textShadowRule = game.boxColor === "#fff200" ? "none" : "0 2px 4px rgba(0,0,0,0.6)";

            return (
                <div class="game-card">
                    <div class="game-header" style={`background-color: ${game.boxColor}; border-bottom: 4px solid rgba(0,0,0,0.25);`}>
                        <h2 class="game-title" style={`color: ${titleColor}; text-shadow: ${textShadowRule};`}>
                            {game.title}
                        </h2>
                    </div>
                    
                    {/* RESTORED: Vital container hooks to stop compiler errors */}
                    <div class="box-contents">
                        <nav class="links-list">
                            {game.files.map((item) => {
                                // 1. DEFAULT PDF ROUTE: If it's a standard PDF file, build the hidden hyphenated array path
                                const folderPathArray = ["", "rulebooks", game.folder, item.file + "-v" + item.version + ".pdf"];
                                let finalUrl = folderPathArray.join('/');

                                // 2. SMART WEB PAGE OVERRIDE: If the file has 'isWebPage: true', use your clean direct URL string instead!
                                if (item.isWebPage) {
                                    finalUrl = item.file;
                                }
            
                                return (
                                    <div class="link-button-wrapper" style="width: 100%;">
                                        <a 
                                            href={finalUrl} 
                                            class="rule-link universal-pdf-trigger" 
                                            style={`border-left: 3px solid ${game.boxColor}; display: flex; width: 100%;`}
                                        >
                                            {item.name} 
                                            <span style="margin-left: auto; font-size: 0.75rem; opacity: 0.6; font-weight: normal; margin-right: 10px;">
                                                v{item.version.replaceAll('-', '.')}
                                            </span>
                                        </a>
                                    </div>
                                );
                            })}
                        </nav>
                    </div>
                </div>
            );
        })}
    
        <div class="section-divider">
            🛠️ In Development Blueprint Stack ({upcomingGames.length} Variants Pipeline)
        </div>

        {upcomingGames.map((upcoming) => (
            <div class="blueprint-card">
                <h2 class="blueprint-title">{upcoming.title}</h2>
                <div class="status-badge">📦 Under Construction</div>
            </div>
        ))}
    </div>

    <!-- Smart PWA Installation Banner Overlay Component -->
    <div id="pwa-banner" class="pwa-install-banner">
        <div class="pwa-header">
            <div class="pwa-title">📱 Add Soloverse to Home Screen</div>
            <button id="pwa-close" class="pwa-close-btn" aria-label="Close popup">×</button>
        </div>
        <div id="pwa-instructions" class="pwa-body">
            <!-- Content will be auto-generated by the script layer based on device profiling -->
        </div>
        <div class="pwa-action-row">
            <button id="pwa-dismiss" class="pwa-btn pwa-btn-secondary">Not Now</button>
            <button id="pwa-action-btn" class="pwa-btn pwa-btn-primary" style="display: none;">Install App</button>
        </div>
    </div>

    <!-- Unified Soloverse Platform Engine: Handles Service Workers, Auto-Theme Detection, and UI Controls -->
    <script is:inline>
        (function() {
            // ==========================================
            // 1. SERVICE WORKER REGISTER & RESET CONTROLS
            // ==========================================
            if ('serviceWorker' in navigator) {
                // Register the background service worker architecture on initial load
                window.addEventListener('load', () => {
                    navigator.serviceWorker.register('/sw.js');
                });

                // Force background service worker registrations to immediately pull fresh server updates from Vercel
                navigator.serviceWorker.getRegistrations().then(function(registrations) {
                    for (let registration of registrations) {
                        registration.update(); 
                    }
                });
            }

            // ==========================================
            // 2. AUTOMATED THEME EVALUATION OR OVERRIDE
            // ==========================================
            const savedTheme = localStorage.getItem('soloverse-theme');
            const devicePrefersDarkMode = window.matchMedia('(prefers-color-scheme: dark)').matches;
            
            let activeTheme = 'dark'; // Base anchor default fallback

            if (savedTheme) {
                // Priority 1: Honor the explicit button selections saved in device memory
                activeTheme = savedTheme;
            } else {
                // Priority 2: Auto-detect and adopt the system mode configuration of the Android/iOS device
                activeTheme = devicePrefersDarkMode ? 'dark' : 'light';
            }

            // Mount evaluated selection instantly to prevent blinding screen flicker loops
            document.documentElement.setAttribute('data-theme', activeTheme);

            // ==========================================
            // 3. UI BUTTON CLICK RUNTIME MANAGEMENT
            // ==========================================
            window.addEventListener('DOMContentLoaded', () => {
                const themeBtn = document.getElementById('theme-toggle-btn');
                if (!themeBtn) return; // Operational guard to stop compiler crashes if the button hasn't loaded yet

                // Initialize the structural text on your shelf button to match active runtime metrics
                updateButtonUI(activeTheme);

                // Setup the mutation event tracker for deliberate player clicks
                themeBtn.addEventListener('click', () => {
                    const currentTheme = document.documentElement.getAttribute('data-theme');
                    const targetTheme = currentTheme === 'dark' ? 'light' : 'dark';
                    
                    document.documentElement.setAttribute('data-theme', targetTheme);
                    localStorage.setItem('soloverse-theme', targetTheme);
                    updateButtonUI(targetTheme);
                });

                function updateButtonUI(theme) {
                    themeBtn.innerText = theme === 'dark' ? '☀️ Light Mode' : '🌙 Dark Mode';
                }
            });

            // ==========================================
            // 4. AUTOMATED PWA INSTALLATION INTERCEPTOR
            // ==========================================
            window.addEventListener('DOMContentLoaded', () => {
                const banner = document.getElementById('pwa-banner');
                const bodyText = document.getElementById('pwa-instructions');
                const closeCross = document.getElementById('pwa-close');
                const dismissBtn = document.getElementById('pwa-dismiss');
                const actionBtn = document.getElementById('pwa-action-btn');

                if (!banner) return; // Structural guard to prevent console errors

                // Verify if the user has already explicitly closed this banner in the past
                if (localStorage.getItem('pwa-banner-dismissed') === 'true') return;

                // Device Profiling Flags
                const isIOS = /iPad|iPhone|iPod/.test(navigator.userAgent) && !window.MSStream;
                const isStandalone = window.matchMedia('(display-mode: standalone)').matches || window.navigator.standalone;

                // Stop execution entirely if the player is already using the installed home screen app version
                if (isStandalone) return;

                let deferredPrompt = null;

                if (isIOS) {
                    // Scenario A: Apple iOS Platform Profiler (Safari Directions Injection)
                    bodyText.innerHTML = "Access the Soloverse platform like a native mobile app! Tap the <strong>Share</strong> button in Safari (square with an up arrow) and select <strong>Add to Home Screen</strong>.";
                    banner.style.display = 'flex';
                } else {
                    // Scenario B: Android / Google Chrome Engine Listener
                    window.addEventListener('beforeinstallprompt', (e) => {
                        // Intercept Chrome's default browser overlay popup strip
                        e.preventDefault();
                        deferredPrompt = e;

                        bodyText.innerHTML = "Install the Soloverse library layout onto your device grid for lightning-fast book rendering and full offline table support.";
                        actionBtn.style.display = 'block';
                        banner.style.display = 'flex';
                    });
                }

                // Interactive Event Triggers for Dismissing or Running Installs
                const hideBanner = () => {
                    banner.style.opacity = '0';
                    setTimeout(() => { banner.style.display = 'none'; }, 300);
                };

                closeCross.addEventListener('click', hideBanner);
                dismissBtn.addEventListener('click', () => {
                    localStorage.setItem('pwa-banner-dismissed', 'true'); // Remembers dismissal setting forever
                    hideBanner();
                });

                actionBtn.addEventListener('click', async () => {
                    if (!deferredPrompt) return;
                    hideBanner();
                    deferredPrompt.prompt(); // Fires native Google Chrome install pipeline dialog layer
                    const { outcome } = await deferredPrompt.userChoice;
                    if (outcome === 'accepted') {
                        localStorage.setItem('pwa-banner-dismissed', 'true');
                    }
                    deferredPrompt = null;
                });
            });

            // ==========================================
            // 5. MANUAL CANVAS ROTATION OVERRIDE CONTROLS
            // ==========================================
            window.addEventListener('DOMContentLoaded', () => {
                const rotateBtn = document.getElementById('rotate-view-btn');
                if (!rotateBtn) return; // Operational guard to stop console errors if button is absent

                let currentRotateState = localStorage.getItem('soloverse-rotate-lock') || 'portrait';
                document.documentElement.setAttribute('data-rotate-override', currentRotateState);

                rotateBtn.addEventListener('click', () => {
                    const activeState = document.documentElement.getAttribute('data-rotate-override');
                    const targetState = activeState === 'landscape' ? 'portrait' : 'landscape';
                    
                    document.documentElement.setAttribute('data-rotate-override', targetState);
                    localStorage.setItem('soloverse-rotate-lock', targetState);
                });
            });

        })();
    </script>

</body>
</html>