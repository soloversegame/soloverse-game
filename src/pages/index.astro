---
// src/pages/index.astro

// 1. Set your current live rulebook version numbers here
const CRAZY_8s = "13.0.0";

// 2. Build the path pointing to your public folder file
const game1Path = `/rulebooks/master-guide-v${CRAZY_8s}.pdf`;
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Game Rulebooks Vault</title>
    <style>
        body {
            font-family: system-ui, sans-serif;
            background: #13151a;
            color: #fff;
            max-width: 600px;
            margin: 40px auto;
            padding: 20px;
            text-align: center;
        }
        .card {
            background: #23262d;
            padding: 20px;
            border-radius: 8px;
            margin-top: 20px;
            border: 1px solid #343844;
        }
        .btn {
            display: inline-block;
            background: #fff;
            color: #13151a;
            padding: 10px 20px;
            border-radius: 4px;
            text-decoration: none;
            font-weight: bold;
            margin-top: 15px;
        }
        .btn:hover {
            background: #dae0e8;
        }
    </style>
</head>
<body>

    <h1>Core Game Archive</h1>
    <p>Select a game variant below to open its live, interactive rulebook.</p>

    <div class="card">
        <h2>Primary Game Rules</h2>
        <p>Current Active Meta: <strong>v{CRAZY_8s}</strong></p>
        
        <!-- This button links directly to your PDF file -->
        <a href={game1Path} target="_blank" class="btn">
            📖 Open Rulebook (iOS Friendly)
        </a>
    </div>

</body>
</html>
