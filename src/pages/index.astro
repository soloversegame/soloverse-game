<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Game Rulebook Vault</title>
    <style>
        body {
            font-family: system-ui, -apple-system, sans-serif;
            background: #111216;
            color: #f3f4f6;
            max-width: 800px;
            margin: 40px auto;
            padding: 20px;
        }
        h1 {
            text-align: center;
            color: #ffffff;
            margin-bottom: 5px;
        }
        .subtitle {
            text-align: center;
            color: #9ca3af;
            margin-bottom: 40px;
        }
        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 20px;
        }
        .game-card {
            background: #1c1e24;
            border: 1px solid #2d3139;
            border-radius: 12px;
            padding: 24px;
            display: flex;
            flex-direction: column;
        }
        .game-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid #2d3139;
            padding-bottom: 12px;
            margin-bottom: 16px;
        }
        .game-title {
            margin: 0;
            font-size: 1.25rem;
            font-weight: 700;
        }
        .links-list {
            display: flex;
            flex-direction: column;
            gap: 10px;
            margin: 0;
            padding: 0;
            list-style: none;
        }
        .rule-link {
            display: flex;
            align-items: center;
            background: #262930;
            color: #e5e7eb;
            text-decoration: none;
            padding: 12px;
            border-radius: 6px;
            font-weight: 500;
            transition: background 0.2s, transform 0.1s;
        }
        .rule-link:hover {
            background: #31353f;
            color: #ffffff;
            transform: translateY(-1px);
        }
    </style>
</head>
<body>

    <h1>Soloverse Rulebook Hub</h1>
    <p class="subtitle">Select a variant blueprint below to stream live, iOS-friendly interactive document layers.</p>

	<div class="grid">
		{gamesList.map((game) => (
			<div class="game-card">
				<div class="game-header">
					<h2 class="game-title">{game.title}</h2>
				</div>
            
				<nav class="links-list">
					{game.files.map((item) => {
						// 1. We build the path with an explicit underscore string breaker
						const fullPath = "/rulebooks/" + game.folder + "/" + item.file + "_v" + item.version + ".pdf";
    
						return (
							<a href={fullPath} target="_blank" class="rule-link">
								{item.name} 
								<span style="margin-left: auto; font-size: 0.75rem; opacity: 0.6;">
									v{item.version}
								</span>
							</a>
						);
					})}
				</nav>
			</div>
		))}
	</div>

</body>
</html>