<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Soloverse Rulebook Hub</title>
    <style>
        body {
            font-family: system-ui, -apple-system, sans-serif;
            background: #0f1015;
            color: #f3f4f6;
            max-width: 900px;
            margin: 40px auto;
            padding: 20px;
        }
        h1 {
            text-align: center;
            color: #ffffff;
            font-size: 2.5rem;
            margin-bottom: 5px;
            font-weight: 800;
            letter-spacing: -0.05em;
        }
        .subtitle {
            text-align: center;
            color: #9ca3af;
            margin-bottom: 50px;
        }
        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
            gap: 30px;
        }
        .game-card {
            background: #171922;
            border-radius: 16px;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.5), 
                        0 8px 10px -6px rgba(0, 0, 0, 0.5);
            transition: transform 0.2s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.2s;
        }
        .game-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.7), 
                        0 10px 10px -5px rgba(0, 0, 0, 0.7);
        }
        .game-header {
            padding: 24px 20px;
            position: relative;
        }
        .game-header::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(to bottom, rgba(255,255,255,0.12), rgba(0,0,0,0.35));
        }
        .game-title {
            position: relative;
            z-index: 10;
            margin: 0;
            font-size: 1.15rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.03em;
        }
        .box-contents {
            padding: 20px;
            background: #1c1e27;
            flex-grow: 1;
            display: flex;
            flex-direction: column;
            gap: 12px;
            border-top: 1px solid rgba(255, 255, 255, 0.05);
        }
        .links-list {
            display: flex;
            flex-direction: column;
            gap: 8px;
            margin: 0;
            padding: 0;
            list-style: none;
        }
        .rule-link {
            display: flex;
            align-items: center;
            background: #242732;
            color: #d1d5db;
            text-decoration: none;
            padding: 12px 14px;
            border-radius: 8px;
            font-weight: 600;
            font-size: 0.9rem;
            border: 1px solid #2d313f;
            transition: background 0.15s, color 0.15s, border-color 0.15s;
        }
        .rule-link:hover {
            background: #2c303f;
            color: #ffffff;
        }
        .section-divider {
            grid-column: 1 / -1;
            margin-top: 60px;
            margin-bottom: 20px;
            border-bottom: 1px dashed #2d3139;
            padding-bottom: 15px;
            color: #6b7280;
            font-size: 1.25rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }
        .blueprint-card {
            background: rgba(23, 25, 34, 0.4);
            border: 2px dashed #2d3139;
            border-radius: 16px;
            padding: 24px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            min-height: 120px;
            position: relative;
            overflow: hidden;
        }
        .blueprint-title {
            margin: 0;
            font-size: 1rem;
            font-weight: 700;
            color: #4b5563;
        }
        .status-badge {
            align-self: flex-start;
            background: #1e293b;
            color: #94a3b8;
            font-size: 0.7rem;
            font-weight: 700;
            padding: 4px 8px;
            border-radius: 4px;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            margin-top: 15px;
        }
    </style>
</head>
<body>

    <h1>Soloverse Rulebook Hub</h1>
    <p class="subtitle">Select a variant blueprint below to stream live, iOS-friendly interactive document layers.</p>

    <div class="grid">
        {gamesList.map((game) => {
            const titleColor = game.boxColor === "#fff200" ? "#111216" : "#ffffff";
            const textShadowRule = game.boxColor === "#fff200" ? "none" : "0 2px 4px rgba(0,0,0,0.6)";

            return (
                <div class="game-card">
                    <div class="game-header" style={`background-color: ${game.boxColor}; border-bottom: 4px solid rgba(0,0,0,0.25);`}>
                        <h2 class="game-title" style={`color: ${titleColor}; text-shadow: ${textShadowRule};`}>
                            {game.title}
                        </h2>
                    </div>
                    
                            {game.files.map((item) => {
                                // 1. Construct the ultra-clean hyphenated file path
                                const rawPdfPath = "/rulebooks/" + game.folder + "/" + item.file + "-v" + item.version + ".pdf";
                                
                                return (
                                    <div class="link-button-wrapper" style="width: 100%;">
                                        {/* ONE UNIFIED BUTTON: Works perfectly across all platforms */}
                                        <a 
                                            href={rawPdfPath} 
                                            target="_blank" 
                                            class="rule-link universal-pdf-trigger" 
                                            style={`border-left: 3px solid ${game.boxColor}; display: flex; width: 100%;`}
                                        >
                                            {item.name} 
                                            <span style="margin-left: auto; font-size: 0.75rem; opacity: 0.6; font-weight: normal; margin-right: 10px;">
                                                v{item.version.replaceAll('-', '.')}
                                            </span>
                                        </a>
                                    </div>
                                );
                            })}
                        </nav>
                    </div>
                </div>
            );
        })}
    
        <div class="section-divider">
            🛠️ In Development Blueprint Stack ({upcomingGames.length} Variants Pipeline)
        </div>

        {upcomingGames.map((upcoming) => (
            <div class="blueprint-card">
                <h2 class="blueprint-title">{upcoming.title}</h2>
                <div class="status-badge">📦 Under Construction</div>
            </div>
        ))}
    </div>

</body>

    <!-- This engineering script unblocks Android Opera GX streaming and bypasses Astro compiler slash checks -->
    <script>
        const isAndroid = /Android/i.test(navigator.userAgent);
        
        if (isAndroid) {
            document.querySelectorAll('.universal-pdf-trigger').forEach(link => {
                link.addEventListener('click', (e) => {
                    e.preventDefault();
                    
                    const fileUrl = link.getAttribute('href');
                    if (fileUrl) {
                        // We safely hide the slashes from the Astro compiler using an array join rule
                        const viewerBase = ["https:", "", "mozilla.github.io", "pdf.js", "web", "viewer.html?file="].join('/');
                        const nativeStreamUrl = viewerBase + encodeURIComponent(window.location.origin + fileUrl);
                        
                        window.open(nativeStreamUrl, '_blank');
                    }
                });
            });
        }
    </script>
</html>