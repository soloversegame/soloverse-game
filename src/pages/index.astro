---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <!-- Permanent Cache-Busting Network Headers -->
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate" />
    <meta http-equiv="Pragma" content="no-cache" />
    <meta http-equiv="Expires" content="0" />

    <title>Soloverse Rulebook Hub</title>

    <!-- 1. Tell the phone browser exactly where your live app blueprint sits -->
    <link rel="manifest" href="/manifest.webmanifest" />

    <!-- 2. Force the mobile address bar and theme layers to adapt to your dark game profile -->
    <meta name="theme-color" content="#0f1015" />

    <style>
        /* 1. DEFINE YOUR REACTIVE COLOR MAP ARCHITECTURE */
        :root {
            --bg-main: #0f1015;
            --bg-card: #171922;
            --bg-contents: #1c1e27;
            --bg-link: #242732;
            --bg-link-hover: #2c303f;
            --text-primary: #ffffff;
            --text-secondary: #f3f4f6;
            --text-muted: #9ca3af;
            --text-divider: #2d3139;
            --shadow-card: rgba(0, 0, 0, 0.5);
        }

        /* 2. AUTOMATIC LIGHT MODE OVERRIDE DATA VALUES */
        :root[data-theme="light"] {
            --bg-main: #f4f5f7;
            --bg-card: #ffffff;
            --bg-contents: #f9fafb;
            --bg-link: #f3f4f6;
            --bg-link-hover: #e5e7eb;
            --text-primary: #111216;
            --text-secondary: #1f2937;
            --text-muted: #4b5563;
            --text-divider: #d1d5db;
            --shadow-card: rgba(0, 0, 0, 0.1);
        }

        body {
            font-family: system-ui, -apple-system, sans-serif;
            background: var(--bg-main);
            color: var(--text-secondary);
            max-width: 900px;
            margin: 40px auto;
            padding: 20px;
            transition: background 0.3s, color 0.3s;
        }
        h1 {
            text-align: center;
            color: var(--text-primary);
            font-size: 2.5rem;
            margin-bottom: 5px;
            font-weight: 800;
            letter-spacing: -0.05em;
        }
        .subtitle {
            text-align: center;
            color: var(--text-muted);
            margin-bottom: 50px;
        }
        
        /* Premium Layout Control Button Interface Switch */
        .theme-toggle-container {
            display: flex;
            justify-content: flex-end;
            margin-bottom: 20px;
        }
        .theme-btn {
            background: var(--bg-card);
            color: var(--text-primary);
            border: 1px solid var(--text-divider);
            padding: 10px 16px;
            border-radius: 50px;
            font-weight: 700;
            cursor: pointer;
            font-size: 0.9rem;
            box-shadow: 0 4px 6px -1px var(--shadow-card);
            transition: background 0.2s, color 0.2s, transform 0.1s;
        }
        .theme-btn:active { transform: scale(0.97); }

        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
            gap: 30px;
        }
        .game-card {
            background: var(--bg-card);
            border-radius: 16px;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            box-shadow: 0 10px 25px -5px var(--shadow-card), 0 8px 10px -6px var(--shadow-card);
            transition: transform 0.2s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.2s;
        }
        .game-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 20px 25px -5px var(--shadow-card), 0 10px 10px -5px var(--shadow-card);
        }
        .game-header {
            padding: 24px 20px;
            position: relative;
        }
        .game-header::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(to bottom, rgba(255,255,255,0.12), rgba(0,0,0,0.35));
        }
        .game-title {
            position: relative;
            z-index: 10;
            margin: 0;
            font-size: 1.15rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.03em;
        }
        .box-contents {
            padding: 20px;
            background: var(--bg-contents);
            flex-grow: 1;
            display: flex;
            flex-direction: column;
            gap: 12px;
            border-top: 1px solid var(--text-divider);
        }
        .links-list {
            display: flex;
            flex-direction: column;
            gap: 8px;
            margin: 0;
            padding: 0;
            list-style: none;
        }
        .rule-link {
            display: flex;
            align-items: center;
            background: var(--bg-link);
            color: var(--text-muted);
            text-decoration: none;
            padding: 12px 14px;
            border-radius: 8px;
            font-weight: 600;
            font-size: 0.9rem;
            border: 1px solid var(--text-divider);
            transition: background 0.15s, color 0.15s, border-color 0.15s;
        }
        .rule-link:hover {
            background: var(--bg-link-hover);
            color: var(--text-primary);
        }
        .section-divider {
            grid-column: 1 / -1;
            margin-top: 60px;
            margin-bottom: 20px;
            border-bottom: 1px dashed var(--text-divider);
            padding-bottom: 15px;
            color: var(--text-muted);
            font-size: 1.25rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }
        .blueprint-card {
            background: var(--bg-card);
            opacity: 0.7;
            border: 2px dashed var(--text-divider);
            border-radius: 16px;
            padding: 24px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            min-height: 120px;
            position: relative;
            overflow: hidden;
        }
        .blueprint-title {
            margin: 0;
            font-size: 1rem;
            font-weight: 700;
            color: var(--text-muted);
        }
        .status-badge {
            align-self: flex-start;
            background: var(--bg-link);
            color: var(--text-muted);
            font-size: 0.7rem;
            font-weight: 700;
            padding: 4px 8px;
            border-radius: 4px;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            margin-top: 15px;
        }
    </style>

</head>
<body>

    <!-- THE REACTIVE THEME OPTION INTERFACE CONTROLLER BUTTON -->
    <div class="theme-toggle-container">
        <button id="theme-toggle-btn" class="theme-btn">☀️ Light Mode</button>
    </div>

    <h1>Soloverse Rulebook Hub</h1>
    <p class="subtitle">Select a Game Variant below to stream live, iOS-friendly interactive document layers.</p>

    <div class="grid">
        {gamesList.map((game) => {
            const titleColor = game.boxColor === "#fff200" ? "#111216" : "#ffffff";
            const textShadowRule = game.boxColor === "#fff200" ? "none" : "0 2px 4px rgba(0,0,0,0.6)";

            return (
                <div class="game-card">
                    <div class="game-header" style={`background-color: ${game.boxColor}; border-bottom: 4px solid rgba(0,0,0,0.25);`}>
                        <h2 class="game-title" style={`color: ${titleColor}; text-shadow: ${textShadowRule};`}>
                            {game.title}
                        </h2>
                    </div>
                    
                    {/* RESTORED: Vital container hooks to stop compiler errors */}
                    <div class="box-contents">
                        <nav class="links-list">
                            {game.files.map((item) => {
                                // 1. DEFAULT PDF ROUTE: If it's a standard PDF file, build the hidden hyphenated array path
                                const folderPathArray = ["", "rulebooks", game.folder, item.file + "-v" + item.version + ".pdf"];
                                let finalUrl = folderPathArray.join('/');

                                // 2. SMART WEB PAGE OVERRIDE: If the file has 'isWebPage: true', use your clean direct URL string instead!
                                if (item.isWebPage) {
                                    finalUrl = item.file;
                                }
            
                                return (
                                    <div class="link-button-wrapper" style="width: 100%;">
                                        <a 
                                            href={finalUrl} 
                                            class="rule-link universal-pdf-trigger" 
                                            style={`border-left: 3px solid ${game.boxColor}; display: flex; width: 100%;`}
                                        >
                                            {item.name} 
                                            <span style="margin-left: auto; font-size: 0.75rem; opacity: 0.6; font-weight: normal; margin-right: 10px;">
                                                v{item.version.replaceAll('-', '.')}
                                            </span>
                                        </a>
                                    </div>
                                );
                            })}
                        </nav>
                    </div>
                </div>
            );
        })}
    
        <div class="section-divider">
            🛠️ In Development Blueprint Stack ({upcomingGames.length} Variants Pipeline)
        </div>

        {upcomingGames.map((upcoming) => (
            <div class="blueprint-card">
                <h2 class="blueprint-title">{upcoming.title}</h2>
                <div class="status-badge">📦 Under Construction</div>
            </div>
        ))}
    </div>

    <script is:inline>
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                navigator.serviceWorker.register('/sw.js');
            });
        }
    </script>

    <!-- Script engine layer to monitor theme mutations and save user local state preferences -->
    <script is:inline>
        const themeBtn = document.getElementById('theme-toggle-btn');
        
        // 1. Check local device memory for an active existing selection setting configuration
        const savedTheme = localStorage.getItem('soloverse-theme') || 'dark';
        document.documentElement.setAttribute('data-theme', savedTheme);
        updateButtonUI(savedTheme);

        themeBtn.addEventListener('click', () => {
            const currentTheme = document.documentElement.getAttribute('data-theme');
            const targetTheme = currentTheme === 'dark' ? 'light' : 'dark';
            
            // 2. Commit the structural change state mutation live on screen
            document.documentElement.setAttribute('data-theme', targetTheme);
            localStorage.setItem('soloverse-theme', targetTheme);
            updateButtonUI(targetTheme);
        });

        function updateButtonUI(theme) {
            themeBtn.innerText = theme === 'dark' ? '☀️ Light Mode' : '🌙 Dark Mode';
        }
    </script>

	<script is:inline>
		// Force immediate update check on all active background service workers
		if ('serviceWorker' in navigator) {
			navigator.serviceWorker.getRegistrations().then(function(registrations) {
				for (let registration of registrations) {
					// Tells the worker to check Vercel edge networks immediately for new builds
					registration.update(); 
				}
			});
		}

		// Keep your active theme preference running alongside the update check
		const activeTheme = localStorage.getItem('soloverse-theme') || 'dark';
		document.documentElement.setAttribute('data-theme', activeTheme);
	</script>

</body>
</html>