<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Soloverse Rulebook Hub</title>
    <style>
        body {
            font-family: system-ui, -apple-system, sans-serif;
            background: #0f1015;
            color: #f3f4f6;
            max-width: 900px;
            margin: 40px auto;
            padding: 20px;
        }
        h1 {
            text-align: center;
            color: #ffffff;
            font-size: 2.5rem;
            margin-bottom: 5px;
            font-weight: 800;
            letter-spacing: -0.05em;
        }
        .subtitle {
            text-align: center;
            color: #9ca3af;
            margin-bottom: 50px;
        }
        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
            gap: 30px;
        }
        .game-card {
            background: #171922;
            border-radius: 16px;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.5), 
                        0 8px 10px -6px rgba(0, 0, 0, 0.5);
            transition: transform 0.2s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.2s;
        }
        .game-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.7), 
                        0 10px 10px -5px rgba(0, 0, 0, 0.7);
        }
        .game-header {
            padding: 24px 20px;
            position: relative;
        }
        /* Cardboard texture gradient filter layer */
        .game-header::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(to bottom, rgba(255,255,255,0.12), rgba(0,0,0,0.35));
        }
        .game-title {
            position: relative;
            z-index: 10;
            margin: 0;
            font-size: 1.15rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.03em;
        }
        .box-contents {
            padding: 20px;
            background: #1c1e27;
            flex-grow: 1;
            display: flex;
            flex-direction: column;
            gap: 12px;
            border-top: 1px solid rgba(255, 255, 255, 0.05);
        }
        .links-list {
            display: flex;
            flex-direction: column;
            gap: 8px;
            margin: 0;
            padding: 0;
            list-style: none;
        }
        .rule-link {
            display: flex;
            align-items: center;
            background: #242732;
            color: #d1d5db;
            text-decoration: none;
            padding: 12px 14px;
            border-radius: 8px;
            font-weight: 600;
            font-size: 0.9rem;
            border: 1px solid #2d313f;
            transition: background 0.15s, color 0.15s, border-color 0.15s;
        }
        .rule-link:hover {
            background: #2c303f;
            color: #ffffff;
        }
    </style>
</head>
<body>

    <h1>Soloverse Rulebook Hub</h1>
    <p class="subtitle">Select a variant blueprint below to stream live, iOS-friendly interactive document layers.</p>

    <div class="grid">
        {gamesList.map((game) => {
            // Dynamic text shadowing contrast logic (Makes text legible on your bright yellow 'Stinger' layout card)
            const titleColor = game.boxColor === "#fff200" ? "#111216" : "#ffffff";
            const textShadowRule = game.boxColor === "#fff200" ? "none" : "0 2px 4px rgba(0,0,0,0.6)";

            return (
                <div class="game-card">
                    <div class="game-header" style={`background-color: ${game.boxColor}; border-bottom: 4px solid rgba(0,0,0,0.25);`}>
                        <h2 class="game-title" style={`color: ${titleColor}; text-shadow: ${textShadowRule};`}>
                            {game.title}
                        </h2>
                    </div>
                    
                    <div class="box-contents">
                        <nav class="links-list">
                            {game.files.map((item) => {
                                const fullPath = "/rulebooks/" + game.folder + "/" + item.file + "_v" + item.version + ".pdf";
            
                                return (
                                    <a href={fullPath} target="_blank" class="rule-link" style={`border-left: 3px solid ${game.boxColor};`}>
                                        {item.name} 
                                        <span style="margin-left: auto; font-size: 0.75rem; opacity: 0.6; font-weight: normal;">
                                            v{item.version}
                                        </span>
                                    </a>
                                );
                            })}
                        </nav>
                    </div>
                </div>
            );
        })}
    </div>

</body>
</html>